+    if (w <= 0) return;
+    var secs = _viewStartSeconds + pos.X / w * ZoomLevels[_zoomIndex];
+    var time = _timelineDay.AddSeconds(secs);
+    ThumbnailCanvas.ToolTip = $"{time:HH:mm:ss}";
+}
