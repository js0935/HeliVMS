<Window x:Class="HeliVMS.Dialog.InputPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="密碼驗證" Width="360" Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="PromptText" Text="請輸入密碼"
                   Foreground="{StaticResource TextBrush}" FontSize="14" Margin="0,0,0,12"/>

        <PasswordBox Grid.Row="1" x:Name="PasswordBox"
                     Style="{StaticResource ModernPasswordBox}"
                     KeyDown="PasswordBox_KeyDown"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Style="{StaticResource SecondaryButton}"
                    Width="80" Height="34" Margin="0,0,8,0"
                    Click="CancelButton_Click" IsCancel="True"/>
            <Button Content="確認" Style="{StaticResource ModernButton}"
                    Width="80" Height="34"
                    Click="ConfirmButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
