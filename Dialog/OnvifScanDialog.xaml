<Window x:Class="HeliVMS.Dialog.OnvifScanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ONVIF 掃描設定"
        Width="420" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ONVIF 掃描設定"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="子網路前綴（例如 192.168.1）" Style="{StaticResource ModernLabel}"/>
                <TextBox x:Name="SubnetBox" Text="192.168.1"
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="ONVIF 連接埠" Style="{StaticResource ModernLabel}"/>
                <TextBox x:Name="PortBox" Text="80"
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="使用者名稱" Style="{StaticResource ModernLabel}"/>
                <TextBox x:Name="UsernameBox" Text="admin"
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="密碼" Style="{StaticResource ModernLabel}"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,4"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Style="{StaticResource SecondaryButton}"
                    Width="80" Height="34" Margin="0,0,8,0"
                    Click="CancelButton_Click"
                    IsCancel="True"/>
            <Button Content="開始掃描" Style="{StaticResource ModernButton}"
                    Width="100" Height="34"
                    Click="ScanButton_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
