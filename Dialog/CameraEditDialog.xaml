<Window x:Class="HeliVMS.Dialog.CameraEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增攝影機"
        Width="500" Height="580"
        MinWidth="460" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="DialogTitle" Grid.Row="0"
                   Text="新增攝影機"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="攝影機名稱" Style="{StaticResource ModernLabel}"/>
                <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="IP 位址" Style="{StaticResource ModernLabel}"/>
                <TextBox x:Name="IpBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"
                         TextChanged="OnFieldChanged"/>

                <TextBlock Text="品牌（選擇後自動填入預設連接埠）" Style="{StaticResource ModernLabel}"/>
                <ComboBox x:Name="BrandCombo" Style="{StaticResource ModernComboBox}"
                          Margin="0,0,0,12"
                          SelectionChanged="BrandCombo_SelectionChanged"/>

                <TextBlock Text="RTSP 連接埠" Style="{StaticResource ModernLabel}"/>
                <TextBox x:Name="PortBox" Text="554" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"
                         TextChanged="OnFieldChanged"/>

                <TextBlock Text="ONVIF 連接埠" Style="{StaticResource ModernLabel}"/>
                <TextBox x:Name="OnvifPortBox" Text="80" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="使用者名稱" Style="{StaticResource ModernLabel}"/>
                <TextBox x:Name="UsernameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"
                         TextChanged="OnFieldChanged"/>

                <TextBlock Text="密碼" Style="{StaticResource ModernLabel}"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,12"
                             PasswordChanged="OnPasswordChanged"/>

                <Separator Background="{StaticResource BorderBrush}" Margin="0,4,0,12"/>

                <TextBlock Text="串流設定" Foreground="{StaticResource TextBrush}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <TextBlock Text="串流1 (Main) — RTSP URL" Style="{StaticResource ModernLabel}"/>
                <TextBox x:Name="RtspUrlBox" Style="{StaticResource ModernTextBox}"
                         IsReadOnly="True" Foreground="{StaticResource SecondaryTextBrush}"
                         Margin="0,0,0,8"/>
                <TextBlock Text="品牌偵測後自動產生，也可手動編輯" Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="11" Margin="0,-4,0,12"/>

                <TextBlock Text="串流2 (Sub) — RTSP URL（選填）" Style="{StaticResource ModernLabel}"/>
                <TextBox x:Name="RtspUrlSubBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"/>

                        <TextBlock Text="攝影機分組（選填）" Style="{StaticResource ModernLabel}"/>
                <ComboBox x:Name="GroupCombo" Style="{StaticResource ModernComboBox}"
                          Margin="0,0,0,12" IsEditable="True"
                          ToolTip="輸入或選擇分組名稱（如：1F 大廳、停車場、機房）"/>

        <Separator Background="{StaticResource BorderBrush}" Margin="0,12,0,8"/>

                <TextBlock Text="移動偵測設定" Foreground="{StaticResource TextBrush}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <CheckBox x:Name="MotionEnabledCheck" Content="啟用移動偵測" FontSize="12"
                          Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"
                          Checked="OnMotionEnabledChanged" Unchecked="OnMotionEnabledChanged"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="靈敏度" VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,4">
                        <Slider x:Name="MotionSensitivitySlider" Width="180" Minimum="0.0" Maximum="1.0"
                                Value="0.5" SmallChange="0.05" LargeChange="0.1" TickFrequency="0.1"
                                ValueChanged="OnMotionSensitivityChanged"
                                Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock x:Name="MotionSensitivityLabel" Text="0.50" FontSize="12"
                                   Foreground="{StaticResource TextBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="低靈敏度 (0.0) ← → 高靈敏度 (1.0)"
                               Grid.ColumnSpan="2" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="0,0,0,4"/>
                </Grid>

                <Separator Background="{StaticResource BorderBrush}" Margin="0,12,0,8"/>

                <TextBlock Text="自動重連設定" Foreground="{StaticResource TextBrush}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <CheckBox x:Name="AutoReconnectCheck" Content="啟用自動重連" FontSize="12"
                          Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"
                          IsChecked="True"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="最大重試次數" VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBox x:Name="MaxRetryBox" Grid.Row="0" Grid.Column="1" Text="0" FontSize="12"
                             Padding="4,3" Margin="8,0,0,4" Width="80" HorizontalAlignment="Left"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="重連間隔（秒）" VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBox x:Name="ReconnectIntervalBox" Grid.Row="1" Grid.Column="1" Text="30" FontSize="12"
                             Padding="4,3" Margin="8,0,0,0" Width="80" HorizontalAlignment="Left"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                </Grid>
                <TextBlock Text="0 = 無限重試" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OnvifDetectButton" Content="ONVIF 偵測"
                    Style="{StaticResource SecondaryButton}"
                    Width="100" Height="34" Margin="0,0,8,0"
                     Click="OnvifDetectButton_Click"/>
            <Button Content="測試連線" Style="{StaticResource SecondaryButton}"
                    Width="80" Height="34" Margin="0,0,8,0"
                    Click="TestConnectionButton_Click"/>
            <Button Content="取消" Style="{StaticResource SecondaryButton}"
                    Width="80" Height="34" Margin="0,0,8,0"
                    Click="CancelButton_Click"
                    IsCancel="True"/>
            <Button Content="儲存" Style="{StaticResource ModernButton}"
                    Width="80" Height="34"
                    Click="SaveButton_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
