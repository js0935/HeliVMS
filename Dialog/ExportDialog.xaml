<Window x:Class="HeliVMS.Dialog.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="匯出錄影片段" Height="380" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="匯出錄影片段" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="開始" VerticalAlignment="Center" FontSize="12"/>
            <DatePicker x:Name="StartDatePicker" Grid.Row="0" Grid.Column="1" Margin="4,0,4,4" FontSize="12"
                        Background="{StaticResource InputBackgroundBrush}" Foreground="{StaticResource TextBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
            <TextBox x:Name="StartTimeBox" Grid.Row="0" Grid.Column="2" Text="00:00:00" Width="70" FontSize="12" Margin="0,0,0,4"
                     Background="{StaticResource InputBackgroundBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="2,2"/>
            <TextBlock Grid.Row="0" Grid.Column="3" Text="HH:mm:ss" FontSize="9" VerticalAlignment="Bottom" Margin="2,0,0,6" Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="結束" VerticalAlignment="Center" FontSize="12"/>
            <DatePicker x:Name="EndDatePicker" Grid.Row="1" Grid.Column="1" Margin="4,0,4,0" FontSize="12"
                        Background="{StaticResource InputBackgroundBrush}" Foreground="{StaticResource TextBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
            <TextBox x:Name="EndTimeBox" Grid.Row="1" Grid.Column="2" Text="23:59:59" Width="70" FontSize="12"
                     Background="{StaticResource InputBackgroundBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="2,2"/>
            <TextBlock Grid.Row="1" Grid.Column="3" Text="HH:mm:ss" FontSize="9" VerticalAlignment="Bottom" Margin="2,0,0,2" Foreground="{StaticResource SecondaryTextBrush}"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="輸出位置" VerticalAlignment="Center" FontSize="12"/>
            <TextBox x:Name="OutputPathBox" Grid.Column="1" FontSize="12" Padding="4,3"
                     Background="{StaticResource InputBackgroundBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="4,0,4,0"/>
            <Button Grid.Column="2" Content="瀏覽..." Padding="8,3" FontSize="11"
                    Click="Browse_Click"
                    Style="{StaticResource SecondaryButton}"/>
        </Grid>

        <TextBlock Grid.Row="3" Text="格式" FontSize="12" Margin="0,0,0,4"/>
        <ComboBox x:Name="FormatCombo" Grid.Row="4" Width="120" HorizontalAlignment="Left" FontSize="12"
                  Style="{StaticResource ModernComboBox}"
                  SelectedIndex="0">
            <ComboBoxItem Tag="mp4">MP4 (H.264)</ComboBoxItem>
            <ComboBoxItem Tag="avi">AVI</ComboBoxItem>
        </ComboBox>

        <TextBlock x:Name="ProgressText" Grid.Row="5" Text="" FontSize="12"
                   Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"
                   Margin="0,8,0,0"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ExportBtn" Content="開始匯出" Width="100"
                    Click="Export_Click"
                    Style="{StaticResource ModernButton}"/>
            <Button Content="取消" Width="80" Margin="8,0,0,0"
                    Click="Cancel_Click"
                    Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
