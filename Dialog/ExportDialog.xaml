<Window x:Class="HeliVMS.Dialog.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="匯出錄影片段" Height="380" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#E1E1E1"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="匯出錄影片段" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="開始時間" VerticalAlignment="Center" FontSize="12"/>
            <DatePicker x:Name="StartDatePicker" Grid.Row="0" Grid.Column="1" Margin="4,0,0,4" FontSize="12"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="結束時間" VerticalAlignment="Center" FontSize="12"/>
            <DatePicker x:Name="EndDatePicker" Grid.Row="1" Grid.Column="1" Margin="4,0,0,0" FontSize="12"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="輸出位置" VerticalAlignment="Center" FontSize="12"/>
            <TextBox x:Name="OutputPathBox" Grid.Column="1" FontSize="12" Padding="4,3"
                     Background="#2D2D2D" Foreground="#E1E1E1" BorderBrush="#444444" BorderThickness="1" Margin="4,0,4,0"/>
            <Button Grid.Column="2" Content="瀏覽..." Padding="8,3" FontSize="11"
                    Click="Browse_Click"
                    Background="#3D3D3D" Foreground="#E1E1E1" BorderBrush="#555555" BorderThickness="1" Cursor="Hand"/>
        </Grid>

        <TextBlock Grid.Row="3" Text="格式" FontSize="12" Margin="0,0,0,4"/>
        <ComboBox x:Name="FormatCombo" Grid.Row="4" Width="120" HorizontalAlignment="Left" FontSize="12"
                  SelectedIndex="0">
            <ComboBoxItem Tag="mp4">MP4 (H.264)</ComboBoxItem>
            <ComboBoxItem Tag="avi">AVI</ComboBoxItem>
        </ComboBox>

        <TextBlock x:Name="ProgressText" Grid.Row="5" Text="" FontSize="12"
                   Foreground="#999999" VerticalAlignment="Center"
                   Margin="0,8,0,0"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ExportBtn" Content="開始匯出" Padding="16,6" FontSize="12" Width="100"
                    Click="Export_Click"
                    Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="取消" Padding="16,6" FontSize="12" Width="80" Margin="8,0,0,0"
                    Click="Cancel_Click"
                    Background="#3D3D3D" Foreground="#E1E1E1" BorderBrush="#555555" BorderThickness="1" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
