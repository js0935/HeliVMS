<Window x:Class="HeliVMS.Dialog.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增用戶"
        Width="460" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="用戶資料"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="帳號" Style="{StaticResource ModernLabel}"/>
                <TextBox x:Name="UsernameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="顯示名稱" Style="{StaticResource ModernLabel}"/>
                <ComboBox x:Name="DisplayNameCombo" Style="{StaticResource ModernComboBox}"
                          Margin="0,0,0,12"
                          SelectionChanged="DisplayNameCombo_SelectionChanged">
                    <ComboBoxItem Content="系統管理員" Tag="Admin"/>
                    <ComboBoxItem Content="使用者" Tag="Operator" IsSelected="True"/>
                    <ComboBoxItem Content="訪客" Tag="Viewer"/>
                </ComboBox>
                <TextBlock Text="（角色會自動對應所選顯示名稱）"
                           FontSize="11"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,-8,0,12"/>

                <TextBlock Text="密碼" Style="{StaticResource ModernLabel}"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,12"/>

                <TextBlock Text="角色" Style="{StaticResource ModernLabel}"/>
                <ComboBox x:Name="RoleCombo" Style="{StaticResource ModernComboBox}" IsEnabled="False">
                    <ComboBoxItem Content="管理員 (Admin)" Tag="Admin"/>
                    <ComboBoxItem Content="操作員 (Operator)" Tag="Operator" IsSelected="True"/>
                    <ComboBoxItem Content="檢視者 (Viewer)" Tag="Viewer"/>
                </ComboBox>

                <CheckBox x:Name="AutoLoginCheckBox" Content="自動登入"
                          Foreground="{StaticResource SecondaryTextBrush}"
                          FontSize="12"
                          Margin="0,12,0,0"/>

                <Border x:Name="TwoFactorSection" BorderThickness="1"
                        BorderBrush="{StaticResource BorderBrush}"
                        CornerRadius="6" Padding="12" Margin="0,12,0,0"
                        Visibility="Collapsed">
                    <StackPanel>
                        <CheckBox x:Name="EnableTwoFactorCheckBox" Content="啟用雙因子驗證 (TOTP)"
                                  Foreground="{StaticResource TextBrush}"
                                  FontSize="12" FontWeight="Bold"
                                  Checked="EnableTwoFactorCheckBox_Checked"
                                  Unchecked="EnableTwoFactorCheckBox_Unchecked"/>
                        <StackPanel x:Name="TwoFactorSecretPanel" Visibility="Collapsed"
                                    Margin="0,8,0,0">
                            <TextBlock Text="使用 Authenticator 應用程式掃描下列 QR Code："
                                       FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="0"
                                    HorizontalAlignment="Center" Margin="0,0,0,8"
                                    Width="160" Height="160">
                                <Image x:Name="QrCodeImage" Width="160" Height="160"
                                       Visibility="Collapsed"/>
                            </Border>
                            <TextBlock Text="或手動輸入金鑰 URI："
                                       FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="8,6">
                                <TextBlock x:Name="TwoFactorSecretText" FontSize="11"
                                           FontFamily="Consolas"
                                           Foreground="{StaticResource TextBrush}"
                                           TextWrapping="Wrap"/>
                            </Border>
                            <Button x:Name="CopyKeyButton" Content="📋 複製金鑰"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="26" FontSize="11" FontWeight="SemiBold"
                                    Cursor="Hand" Margin="0,6,0,0"
                                    Click="CopyKeyButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="PermissionsSection" BorderThickness="1"
                        BorderBrush="{StaticResource BorderBrush}"
                        CornerRadius="6" Padding="12" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="功能權限（僅非管理員角色可設定）"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,8"/>
                        <CheckBox x:Name="PermDeviceMgmt" Content="設備管理"
                                  Tag="DeviceManagement" Margin="0,2"
                                  Foreground="White"/>
                        <CheckBox x:Name="PermPlayback" Content="錄影回放"
                                  Tag="Playback" Margin="0,2"
                                  Foreground="White"/>
                        <CheckBox x:Name="PermSystemSettings" Content="系統設定"
                                  Tag="SystemSettings" Margin="0,2"
                                  Foreground="White"/>
                        <CheckBox x:Name="PermLicense" Content="授權管理"
                                  Tag="License" Margin="0,2"
                                  Foreground="White"/>
                        <CheckBox x:Name="PermPTZ" Content="PTZ 雲台控制"
                                  Tag="PTZControl" Margin="0,2"
                                  Foreground="White"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Style="{StaticResource SecondaryButton}"
                    Width="80" Height="34" Margin="0,0,8,0"
                    Click="CancelButton_Click"
                    IsCancel="True"/>
            <Button x:Name="SaveButton" Content="套用" Style="{StaticResource ModernButton}"
                    Width="80" Height="34"
                    Click="SaveButton_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
