<Window x:Class="HeliVMS.Dialog.CameraPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title, RelativeSource={RelativeSource Self}}"
        Height="400" Width="320"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#E1E1E1"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{Binding Title, RelativeSource={RelativeSource Self}}"
                   FontSize="14" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,12"/>
        <ListBox Grid.Row="1" x:Name="CameraCheckListBox"
                 Background="#2D2D2D" BorderBrush="#444444"
                 Foreground="#E1E1E1" FontSize="12">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked}"
                              FontSize="12" Foreground="#E1E1E1" Margin="4,2"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="確定" Padding="16,6" FontSize="12" Width="80"
                    Click="Ok_Click"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="取消" Padding="16,6" FontSize="12" Width="80" Margin="8,0,0,0"
                    Click="Cancel_Click"
                    Background="#3D3D3D" Foreground="#E1E1E1"
                    BorderBrush="#555555" BorderThickness="1" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
