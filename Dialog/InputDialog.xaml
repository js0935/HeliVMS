<Window x:Class="HeliVMS.Dialog.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="輸入"
        Width="400" Height="160"
        MinWidth="300" MinHeight="140"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="PromptText" Text="請輸入："
                   Foreground="{StaticResource TextBrush}" FontSize="13" Margin="0,0,0,8"/>
        <TextBox Grid.Row="1" x:Name="InputBox" Style="{StaticResource ModernTextBox}"
                 VerticalAlignment="Top"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="確定" Style="{StaticResource ModernButton}" Width="80" Height="30"
                    Click="OkButton_Click" Margin="0,0,8,0"
                    IsDefault="True"/>
            <Button Content="取消" Style="{StaticResource SecondaryButton}" Width="80" Height="30"
                    Click="CancelButton_Click"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
