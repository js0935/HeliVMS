<Window x:Class="HeliVMS.Dialog.EventRuleEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="編輯事件規則" Height="520" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#E1E1E1"
        SnapsToDevicePixels="True"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="規則名稱" FontSize="11" Foreground="#999999" Margin="0,0,0,2"/>
                    <TextBox x:Name="RuleNameBox" FontSize="13" Padding="6,4"
                             Background="#2D2D2D" Foreground="#E1E1E1"
                             BorderBrush="#444444" BorderThickness="1" Width="280"/>
                </StackPanel>
                <CheckBox x:Name="EnabledCheck" Content="啟用" Grid.Column="1"
                          FontSize="12" VerticalAlignment="Bottom" Margin="0,0,0,6"
                          Foreground="#CCCCCC"/>
            </Grid>
            <TextBox x:Name="DescBox" Text="" FontSize="11" Padding="6,4"
                     Background="#2D2D2D" Foreground="#999999"
                     BorderBrush="#444444" BorderThickness="1" Margin="0,6,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Text="條件" FontSize="12" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                <ListBox x:Name="ConditionsList" Height="140"
                         Background="#2D2D2D" BorderBrush="#444444"
                         Foreground="#E1E1E1" FontSize="12"
                         SelectionChanged="ConditionsList_SelectionChanged"/>
                <WrapPanel Margin="0,4,0,0">
                    <Button Content="+ 條件" Padding="8,3" FontSize="11"
                            Click="AddCondition_Click" Width="65"
                            Background="#3D3D3D" Foreground="#E1E1E1"
                            BorderBrush="#555555" BorderThickness="1" Cursor="Hand"/>
                    <Button Content="刪除" Padding="8,3" FontSize="11" Margin="4,0,0,0"
                            Click="RemoveCondition_Click"
                            Background="#3D3D3D" Foreground="#E1E1E1"
                            BorderBrush="#555555" BorderThickness="1" Cursor="Hand"/>
                </WrapPanel>

                <!-- Time condition editor -->
                <Border Background="#252525" BorderBrush="#444444" BorderThickness="1" Margin="0,8,0,0" Padding="8" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="時段條件（選填）" FontSize="11" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="開始" FontSize="11" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,6,4"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TimeStartBox" Text="08:00" FontSize="11" Padding="4,2"
                                     Background="#2D2D2D" Foreground="#E1E1E1" BorderBrush="#444444" BorderThickness="1" Margin="0,0,0,4"
                                     TextChanged="TimeCondition_Changed"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="結束" FontSize="11" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,6,4"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TimeEndBox" Text="18:00" FontSize="11" Padding="4,2"
                                     Background="#2D2D2D" Foreground="#E1E1E1" BorderBrush="#444444" BorderThickness="1" Margin="0,0,0,4"
                                     TextChanged="TimeCondition_Changed"/>
                        </Grid>
                        <WrapPanel Margin="0,4,0,0">
                            <CheckBox x:Name="DayMon" Content="一" FontSize="11" Foreground="#CCCCCC" Margin="0,0,6,0" IsChecked="True" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed"/>
                            <CheckBox x:Name="DayTue" Content="二" FontSize="11" Foreground="#CCCCCC" Margin="0,0,6,0" IsChecked="True" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed"/>
                            <CheckBox x:Name="DayWed" Content="三" FontSize="11" Foreground="#CCCCCC" Margin="0,0,6,0" IsChecked="True" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed"/>
                            <CheckBox x:Name="DayThu" Content="四" FontSize="11" Foreground="#CCCCCC" Margin="0,0,6,0" IsChecked="True" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed"/>
                            <CheckBox x:Name="DayFri" Content="五" FontSize="11" Foreground="#CCCCCC" Margin="0,0,6,0" IsChecked="True" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed"/>
                            <CheckBox x:Name="DaySat" Content="六" FontSize="11" Foreground="#CCCCCC" Margin="0,0,6,0" IsChecked="True" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed"/>
                            <CheckBox x:Name="DaySun" Content="日" FontSize="11" Foreground="#CCCCCC" IsChecked="True" Checked="DayCheck_Changed" Unchecked="DayCheck_Changed"/>
                        </WrapPanel>
                        <TextBlock Text="未勾選任何時段或日期 = 不限制" FontSize="9" Foreground="#888888" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Text="動作" FontSize="12" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                <ListBox x:Name="ActionsList" Height="200"
                         Background="#2D2D2D" BorderBrush="#444444"
                         Foreground="#E1E1E1" FontSize="12"/>
                <WrapPanel Margin="0,4,0,0">
                    <Button Content="+ 動作" Padding="8,3" FontSize="11"
                            Click="AddAction_Click" Width="65"
                            Background="#3D3D3D" Foreground="#E1E1E1"
                            BorderBrush="#555555" BorderThickness="1" Cursor="Hand"/>
                    <Button Content="刪除" Padding="8,3" FontSize="11" Margin="4,0,0,0"
                            Click="RemoveAction_Click"
                            Background="#3D3D3D" Foreground="#E1E1E1"
                            BorderBrush="#555555" BorderThickness="1" Cursor="Hand"/>
                </WrapPanel>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="確定" Padding="16,6" FontSize="12" Width="80"
                    Click="Ok_Click"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="取消" Padding="16,6" FontSize="12" Width="80" Margin="8,0,0,0"
                    Click="Cancel_Click"
                    Background="#3D3D3D" Foreground="#E1E1E1"
                    BorderBrush="#555555" BorderThickness="1" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
