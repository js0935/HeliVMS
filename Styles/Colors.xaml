<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme color palette -->
    <Color x:Key="BackgroundColor">#FF1A1A2E</Color>
    <Color x:Key="SurfaceColor">#FF16213E</Color>
    <Color x:Key="SecondarySurfaceColor">#FF0F3460</Color>
    <Color x:Key="PrimaryColor">#FF00A8FF</Color>
    <Color x:Key="PrimaryHoverColor">#FF3399FF</Color>
    <Color x:Key="AccentColor">#FFE94560</Color>
    <Color x:Key="SuccessColor">#FF00C897</Color>
    <Color x:Key="WarningColor">#FFFFA500</Color>
    <Color x:Key="ErrorColor">#FFFF4444</Color>
    <Color x:Key="TextColor">#FFE0E0E0</Color>
    <Color x:Key="SecondaryTextColor">#FF909090</Color>
    <Color x:Key="BorderColor">#FF2A2A4A</Color>
    <Color x:Key="DividerColor">#FF333355</Color>
    <Color x:Key="SidebarColor">#FF0D1117</Color>
    <Color x:Key="SidebarHoverColor">#FF1A1A2E</Color>
    <Color x:Key="SidebarActiveColor">#FF16213E</Color>
    <Color x:Key="InputBackgroundColor">#FF1E1E3A</Color>
    <Color x:Key="OverlayColor">#80000000</Color>

    <!-- Recording type colors (Nx Witness standard) -->
    <Color x:Key="RecordingContinuousColor">#FF2196F3</Color>
    <Color x:Key="RecordingMotionColor">#FFFF5722</Color>
    <Color x:Key="RecordingAlarmColor">#FFF44336</Color>
    <Color x:Key="RecordingAiColor">#FFFFC107</Color>

    <!-- Brush resources -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SecondarySurfaceBrush" Color="{StaticResource SecondarySurfaceColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}"/>
    <SolidColorBrush x:Key="RecordingContinuousBrush" Color="{StaticResource RecordingContinuousColor}"/>
    <SolidColorBrush x:Key="RecordingMotionBrush" Color="{StaticResource RecordingMotionColor}"/>
    <SolidColorBrush x:Key="RecordingAlarmBrush" Color="{StaticResource RecordingAlarmColor}"/>
    <SolidColorBrush x:Key="RecordingAiBrush" Color="{StaticResource RecordingAiColor}"/>
</ResourceDictionary>
