<Window x:Class="HeliVMS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HeliVMS.Controls"
        Title="HeliVMS — 智慧影像管理系統"
        Height="768" Width="1024"
        WindowState="Maximized"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="MainWindow_Loaded"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavColumn" Width="45"/>
                <ColumnDefinition x:Name="DrawerColumn" Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="NotifColumn" Width="Auto"/>
            </Grid.ColumnDefinitions>

        <!-- ═══ Column 0: Nav Bar (permanent 45px) ═══ -->
        <Border Grid.Column="0" Width="45" Background="#141414">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <Button x:Name="BtnLive" Content="🖥" Width="45" Height="42" Padding="0"
                            Style="{StaticResource NavButton}"
                            ToolTip="即時/回放監看"
                            Click="BtnLive_Click"/>
                    <Button x:Name="BtnDevice" Content="📁" Width="45" Height="42" Padding="0"
                            Style="{StaticResource NavButton}"
                            ToolTip="設備管理"
                            Click="BtnDevice_Click"/>
                    <Button x:Name="BtnLicense" Content="🔑" Width="45" Height="42" Padding="0"
                            Style="{StaticResource NavButton}"
                            ToolTip="授權管理"
                            Click="BtnLicense_Click"/>
                    <Button x:Name="BtnSettings" Content="⚙" Width="45" Height="42" Padding="0"
                            Style="{StaticResource NavButton}"
                            ToolTip="系統設定"
                            Click="BtnSettings_Click"/>
                    <Button x:Name="BtnTheme" Content="☀" Width="45" Height="42" Padding="0"
                            Style="{StaticResource NavButton}"
                            ToolTip="切換主題"
                            Click="BtnThemeToggle_Click"/>
                </StackPanel>
                <Button x:Name="BtnNotification" Grid.Row="1"
                        Width="45" Height="42" Padding="0"
                        Style="{StaticResource NavButton}"
                        ToolTip="通知紀錄"
                        Click="ToggleNotifPanel_Click">
                    <Grid>
                        <TextBlock Text="🔔" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border x:Name="NotifBadge" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="#F44336" CornerRadius="6" MinWidth="12" Height="12"
                                Margin="0,4,4,0" Padding="2,0" BorderThickness="0">
                            <TextBlock x:Name="NotifBadgeText" Text="0" FontSize="8"
                                       Foreground="White" TextAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>
                <Button x:Name="BtnUser" Grid.Row="2"
                        Content="👤" Width="45" Height="42" Padding="0"
                        Style="{StaticResource NavButton}"
                        ToolTip="洪俊士 (Jiunn Shyh Hung)"/>
            </Grid>
        </Border>
        <!-- ═══ Notification bell + flyout ═══ -->
        <Popup x:Name="NotificationPopup" Grid.Column="1" Placement="Absolute" Width="340" Height="400"
               AllowsTransparency="True" StaysOpen="False" PopupAnimation="Slide">
            <Border Background="#1E1E1E" CornerRadius="8" BorderThickness="1" BorderBrush="#33FFFFFF">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="通知紀錄" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="全部已讀" FontSize="11" Height="24" Padding="8,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource SecondaryTextBrush}" Cursor="Hand"
                                Click="MarkAllNotifRead_Click"/>
                    </Grid>
                    <ListBox Grid.Row="1" x:Name="NotificationList" Margin="0,8,0,8"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                 <Border Padding="6" Margin="0,0,0,4"
                                        CornerRadius="4" Background="#0DFFFFFF"
                                        Tag="{Binding}">
                                     <Border.ContextMenu>
                                         <ContextMenu>
                                             <MenuItem Header="標記為已讀"
                                                       Click="MarkNotifRead_Click"
                                                       Tag="{Binding}"/>
                                         </ContextMenu>
                                     </Border.ContextMenu>
                                     <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Timestamp, StringFormat=\{0:MM/dd HH:mm:ss\}}"
                                                       FontSize="10" Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Message}" FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap" MaxHeight="32"/>
                                        </StackPanel>
                                        <Ellipse Grid.Column="1" Width="8" Height="8" Fill="#FF4CAF50"
                                                 VerticalAlignment="Top" Margin="4,0,0,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <WrapPanel Grid.Row="2">
                        <Button Content="關閉" FontSize="11" Height="24" Padding="12,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource SecondaryTextBrush}" Cursor="Hand"
                                Click="CloseNotifPopup_Click"/>
                        <Button Content="清除全部" FontSize="11" Height="24" Padding="12,0" Margin="8,0,0,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#FFE57373" Cursor="Hand"
                                Click="ClearAllNotif_Click"/>
                    </WrapPanel>
                </Grid>
            </Border>
        </Popup>

        <!-- ═══ Column 1: Drawer (animated width via inner container) ═══ -->
        <Grid Grid.Column="1" ClipToBounds="True">
            <Border x:Name="DrawerContainer" Width="175" Background="#FF000000">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Logo -->
                    <Border Grid.Row="0" Height="42" Background="#FF000000"
                            BorderThickness="0,0,0,1" BorderBrush="#33FFFFFF">
                        <TextBlock Text="HeliVMS" FontSize="14" FontWeight="Bold"
                                   Foreground="#FFFFFFFF"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Border>
                    <!-- Camera tree (Live mode) -->
                    <controls:CameraTreePanel x:Name="LiveDrawer" Grid.Row="1"/>
                    <!-- Sub-menu drawer (non-Live modes) -->
                    <Border x:Name="SubMenuDrawer" Grid.Row="1" Visibility="Collapsed"
                            Background="#FF000000"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ Column 2: Main Work Area ═══ -->
            <ContentControl x:Name="MainWorkArea" Grid.Column="2"/>

        <!-- ═══ Column 3: Notifications Panel ═══ -->
        <GridSplitter Grid.Column="3" Width="3" ResizeBehavior="PreviousAndNext"
                      Background="Transparent" IsHitTestVisible="False"/>
            <controls:NotificationsPanel x:Name="NotifSidePanel" Grid.Column="3" Width="260"
                                          Visibility="Collapsed"/>

        <!-- Toast Notification -->
        <Border Grid.Column="2" x:Name="ToastOverlay"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,16,0" Visibility="Collapsed"
                Background="#E0000000" CornerRadius="8" Padding="14,10" MaxWidth="360"
                BorderThickness="1" BorderBrush="#33FFFFFF">
            <TextBlock x:Name="ToastText" Text="" FontSize="12" Foreground="#E1E1E1"
                       TextWrapping="Wrap"/>
        </Border>
        </Grid>
        <!-- ═══ Status Bar ═══ -->
        <Border Grid.Row="1" Height="24" Background="#141414" BorderThickness="0,1,0,0" BorderBrush="#33FFFFFF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusCameras" Text="" FontSize="11" Foreground="#AAFFFFFF" Margin="8,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="StatusBandwidth" Text="" FontSize="11" Foreground="#AAFFFFFF" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="StatusStorage" Text="" FontSize="11" Foreground="#AAFFFFFF" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" x:Name="StatusCpu" Text="" FontSize="11" Foreground="#AAFFFFFF" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" x:Name="StatusMemory" Text="" FontSize="11" Foreground="#AAFFFFFF" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="" FontSize="11" Foreground="#AAFFFFFF" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="6" x:Name="StatusTime" Text="" FontSize="11" Foreground="#AAFFFFFF" Margin="0,0,8,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>