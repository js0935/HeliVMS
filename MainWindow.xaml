<Window x:Class="HeliVMS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HeliVMS.Controls"
        Title="HeliVMS — 智慧影像管理系統"
        Height="768" Width="1024"
        WindowState="Maximized"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="MainWindow_Loaded"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavColumn" Width="48"/>
                <ColumnDefinition x:Name="DrawerColumn" Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="NotifColumn" Width="Auto"/>
            </Grid.ColumnDefinitions>

        <!-- ═══ Column 0: Nav Bar (permanent 48px) ═══ -->
        <Border Grid.Column="0" Width="48" Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,4,0,0">
                    <Button x:Name="BtnLive"
                            Style="{StaticResource SidebarButton}"
                            ToolTip="即時/回放監看"
                            Click="BtnLive_Click">
                        <Button.ContextMenu>
                            <ContextMenu Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                                        BorderBrush="{StaticResource BorderBrush}">
                                <MenuItem Header="新增攝影機" Click="AddCameraMenu_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconPlus}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="ONVIF 掃描" Click="OnvifScanMenu_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconSearch}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator Background="{StaticResource BorderBrush}"/>
                                <MenuItem Header="切換全螢幕" Click="ToggleFullscreenMenu_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconFullScreen}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Viewbox Width="20" Height="20" Stretch="Uniform">
                            <Path Data="{StaticResource IconLive}" Fill="{StaticResource SecondaryTextBrush}"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="BtnDevice"
                            Style="{StaticResource SidebarButton}"
                            ToolTip="設備管理"
                            Click="BtnDevice_Click">
                        <Button.ContextMenu>
                            <ContextMenu Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                                        BorderBrush="{StaticResource BorderBrush}">
                                <MenuItem Header="新增攝影機" Click="AddCameraMenu_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconPlus}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="ONVIF 掃描" Click="OnvifScanMenu_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconSearch}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="匯入 CSV" Click="ImportCsvMenu_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconExport}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator Background="{StaticResource BorderBrush}"/>
                                <MenuItem Header="頻道管理" Click="ChannelManagementMenu_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconSettings}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Viewbox Width="20" Height="20" Stretch="Uniform">
                            <Path Data="{StaticResource IconDevice}" Fill="{StaticResource SecondaryTextBrush}"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="BtnLicense"
                            Style="{StaticResource SidebarButton}"
                            ToolTip="授權管理"
                            Click="BtnLicense_Click">
                        <Viewbox Width="20" Height="20" Stretch="Uniform">
                            <Path Data="{StaticResource IconKey}" Fill="{StaticResource SecondaryTextBrush}"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="BtnDashboard"
                            Style="{StaticResource SidebarButton}"
                            ToolTip="系統儀表板"
                            Click="BtnDashboard_Click">
                        <Viewbox Width="20" Height="20" Stretch="Uniform">
                            <Path Data="{StaticResource IconDashboard}" Fill="{StaticResource SecondaryTextBrush}"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="BtnEMap"
                            Style="{StaticResource SidebarButton}"
                            ToolTip="電子地圖"
                            Click="BtnEMap_Click">
                        <Button.ContextMenu>
                            <ContextMenu Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                                        BorderBrush="{StaticResource BorderBrush}">
                                <MenuItem Header="新增樓層" Click="AddFloorMenu_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconPlus}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="載入地圖" Click="LoadMapMenu_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconMap}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Viewbox Width="20" Height="20" Stretch="Uniform">
                            <Path Data="{StaticResource IconMap}" Fill="{StaticResource SecondaryTextBrush}"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="BtnSettings"
                            Style="{StaticResource SidebarButton}"
                            ToolTip="系統設定"
                            Click="BtnSettings_Click">
                        <Button.ContextMenu>
                            <ContextMenu Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                                        BorderBrush="{StaticResource BorderBrush}">
                                <MenuItem Header="系統日誌" Click="SubSettingsLog_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconInfo}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="使用者管理" Click="SubSettingsUser_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconUser}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="事件規則" Click="SubSettingsEventRules_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconWarning}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator Background="{StaticResource BorderBrush}"/>
                                <MenuItem Header="全部設定" Click="BtnSettings_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconSettings}" Fill="{StaticResource PrimaryBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Viewbox Width="20" Height="20" Stretch="Uniform">
                            <Path Data="{StaticResource IconSettings}" Fill="{StaticResource SecondaryTextBrush}"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <Line Style="{StaticResource SidebarSeparator}"/>
                    <Button x:Name="BtnTheme"
                            Style="{StaticResource SidebarButton}"
                            ToolTip="切換主題"
                            Click="BtnThemeToggle_Click">
                        <Viewbox Width="20" Height="20" Stretch="Uniform">
                            <Path Data="{StaticResource IconTheme}" Fill="{StaticResource SecondaryTextBrush}"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="BtnNotification"
                            Style="{StaticResource SidebarButton}"
                            ToolTip="通知紀錄"
                            Click="ToggleNotifPanel_Click">
                        <Grid>
                            <Viewbox Width="20" Height="20" Stretch="Uniform">
                                <Path Data="{StaticResource IconBell}" Fill="{StaticResource SecondaryTextBrush}"/>
                            </Viewbox>
                            <Border x:Name="NotifBadge" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="{StaticResource ErrorBrush}" CornerRadius="6" MinWidth="12" Height="12"
                                    Margin="0,4,4,0" Padding="2,0" BorderThickness="0">
                                <TextBlock x:Name="NotifBadgeText" Text="0" FontSize="8"
                                           Foreground="{StaticResource TextBrush}" TextAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>
                    <Button x:Name="BtnUser"
                            Style="{StaticResource SidebarButton}"
                            ToolTip="洪俊士 (Jiunn Shyh Hung)">
                        <Button.ContextMenu>
                            <ContextMenu Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                                        BorderBrush="{StaticResource BorderBrush}">
                                <MenuItem Header="使用者管理" Click="SubSettingsUser_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconUser}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator Background="{StaticResource BorderBrush}"/>
                                <MenuItem Header="關於 HeliVMS" Click="BtnAbout_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconInfo}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator Background="{StaticResource BorderBrush}"/>
                                <MenuItem Header="登出" Click="BtnLogout_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconLogout}" Fill="{StaticResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="結束" Click="BtnExit_Click">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconClose}" Fill="{StaticResource ErrorBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Viewbox Width="20" Height="20" Stretch="Uniform">
                            <Path Data="{StaticResource IconUser}" Fill="{StaticResource SecondaryTextBrush}"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <!-- ═══ Notification bell + flyout ═══ -->
        <Popup x:Name="NotificationPopup" Grid.Column="1" Placement="Absolute" Width="340" Height="400"
               AllowsTransparency="True" StaysOpen="False" PopupAnimation="Slide">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="通知紀錄" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="全部已讀" FontSize="11" Height="24" Padding="8,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource PrimaryBrush}" Cursor="Hand"
                        Click="MarkAllNotifRead_Click"/>
                    </Grid>
                    <ListBox Grid.Row="1" x:Name="NotificationList" Margin="0,8,0,8"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                 <Border Padding="6" Margin="0,0,0,4"
                                         CornerRadius="4" Background="{StaticResource SurfaceBrush}"
                                        Tag="{Binding}">
                                     <Border.ContextMenu>
                                         <ContextMenu>
                                             <MenuItem Header="標記為已讀"
                                                       Click="MarkNotifRead_Click"
                                                       Tag="{Binding}"/>
                                         </ContextMenu>
                                     </Border.ContextMenu>
                                     <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Timestamp, StringFormat=\{0:MM/dd HH:mm:ss\}}"
                                                       FontSize="10" Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Message}" FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap" MaxHeight="32"/>
                                        </StackPanel>
                                        <Ellipse Grid.Column="1" Width="8" Height="8" Fill="#FF4CAF50"
                                                 VerticalAlignment="Top" Margin="4,0,0,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <WrapPanel Grid.Row="2">
                        <Button Content="關閉" FontSize="11" Height="24" Padding="12,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource SecondaryTextBrush}" Cursor="Hand"
                                Click="CloseNotifPopup_Click"/>
                        <Button Content="清除全部" FontSize="11" Height="24" Padding="12,0" Margin="8,0,0,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource AccentBrush}" Cursor="Hand"
                                Click="ClearAllNotif_Click"/>
                    </WrapPanel>
                </Grid>
            </Border>
        </Popup>

        <!-- ═══ Column 1: Drawer (animated width via inner container) ═══ -->
        <Grid Grid.Column="1" ClipToBounds="True">
            <Border x:Name="DrawerContainer" Width="220" Background="{StaticResource SidebarBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Logo + header -->
                    <Border Grid.Row="0" Height="42" Background="{StaticResource SidebarBrush}"
                            BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                        <Grid Margin="10,0,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconCamera}" Fill="{StaticResource TextBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="HeliVMS" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <!-- Search bar (visible in Live mode) -->
                    <Border x:Name="DrawerSearchBar" Grid.Row="1" Height="32" Background="{StaticResource SurfaceBrush}"
                            BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                            Padding="8,0" Visibility="Visible">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="搜尋資源" FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="2" x:Name="QuickAddCameraBtn" Width="20" Height="20" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    Cursor="Hand" FontSize="14" FontWeight="Bold"
                                    ToolTip="新增攝影機"
                                    Click="QuickAddCameraBtn_Click">
                                <Path Data="{StaticResource IconPlus}" Fill="{StaticResource SecondaryTextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                        </Grid>
                    </Border>
                    <!-- Camera tree (Live mode) -->
                    <controls:CameraTreePanel x:Name="LiveDrawer" Grid.Row="2"/>
                    <!-- Sub-menu drawer (non-Live modes) -->
                    <Border x:Name="SubMenuDrawer" Grid.Row="2" Visibility="Collapsed"
                            Background="{StaticResource SidebarBrush}">
                        <Grid Margin="0,8,0,0">
                            <!-- Settings sub-menu -->
                            <ScrollViewer x:Name="SettingsSubMenu" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="設定分類" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Margin="12,0,12,4"/>
                                    <Button x:Name="SubSettingsLog" Content="系統日誌" Tag="0" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubSettingsFfmpeg" Content="FFmpeg" Tag="1" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubSettingsFont" Content="字型設定" Tag="2" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubSettingsRetention" Content="錄影保留" Tag="3" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubSettingsUser" Content="使用者管理" Tag="4" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubSettingsDebug" Content="除錯" Tag="5" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubSettingsMediaMTX" Content="MediaMTX" Tag="6" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubSettingsEventRules" Content="事件規則" Tag="7" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubSettingsNotification" Content="通知設定" Tag="8" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubSettingsSchedule" Content="錄影排程" Tag="9" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubSettingsBackup" Content="備份還原" Tag="10" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                            <!-- Device sub-menu -->
                            <ScrollViewer x:Name="DeviceSubMenu" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="裝置分類" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Margin="12,0,12,4"/>
                                    <Button x:Name="SubDeviceCamera" Content="攝影機管理" Tag="0" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubDeviceRecording" Content="錄影排程" Tag="1" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubDeviceStorage" Content="儲存管理" Tag="2" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubDeviceChannel" Content="頻道管理" Tag="3" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                    <Button x:Name="SubDeviceGroup" Content="攝影機群組" Tag="4" Style="{StaticResource SidebarButton}" Click="SubMenuItem_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ Column 2: Main Work Area ═══ -->
            <ContentControl x:Name="MainWorkArea" Grid.Column="2"/>

        <!-- ═══ Column 3: Notifications Panel ═══ -->
        <GridSplitter Grid.Column="3" Width="3" ResizeBehavior="PreviousAndNext"
                      Background="Transparent" IsHitTestVisible="False"/>
            <controls:NotificationsPanel x:Name="NotifSidePanel" Grid.Column="3" Width="260"
                                          Visibility="Collapsed"/>

        <!-- Toast Notification -->
        <Border Grid.Column="2" x:Name="ToastOverlay"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,16,0" Visibility="Collapsed"
                Background="{StaticResource OverlayBrush}" CornerRadius="8" Padding="14,10" MaxWidth="360"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <TextBlock x:Name="ToastText" Text="" FontSize="12" Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"/>
        </Border>
        </Grid>
        <!-- ═══ Status Bar ═══ -->
        <Border Grid.Row="1" Height="24" Background="{StaticResource SidebarBrush}" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusCameras" Text="" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="8,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="StatusBandwidth" Text="" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="StatusStorage" Text="" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" x:Name="StatusCpu" Text="" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" x:Name="StatusMemory" Text="" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="6" x:Name="StatusTime" Text="" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>