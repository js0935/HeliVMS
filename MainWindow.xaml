<Window x:Class="HeliVMS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HeliVMS.Controls"
        Title="HeliVMS — 智慧影像管理系統"
        Height="768" Width="1024"
        WindowState="Maximized"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="MainWindow_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="45"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Column 0: Nav Bar (permanent 45px) ═══ -->
        <Border Grid.Column="0" Width="45" Background="#141414">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <Button x:Name="BtnLive" Content="🖥" Width="45" Height="42" Padding="0"
                            Style="{StaticResource NavButton}"
                            ToolTip="即時/回放監看"
                            Click="BtnLive_Click"/>
                    <Button x:Name="BtnDevice" Content="📁" Width="45" Height="42" Padding="0"
                            Style="{StaticResource NavButton}"
                            ToolTip="設備管理"
                            Click="BtnDevice_Click"/>
                    <Button x:Name="BtnLicense" Content="🔑" Width="45" Height="42" Padding="0"
                            Style="{StaticResource NavButton}"
                            ToolTip="授權管理"
                            Click="BtnLicense_Click"/>
                    <Button x:Name="BtnSettings" Content="⚙" Width="45" Height="42" Padding="0"
                            Style="{StaticResource NavButton}"
                            ToolTip="系統設定"
                            Click="BtnSettings_Click"/>
                </StackPanel>
                <Button x:Name="BtnUser" Grid.Row="1"
                        Content="👤" Width="45" Height="42" Padding="0"
                        Style="{StaticResource NavButton}"
                        ToolTip="洪俊士 (Jiunn Shyh Hung)"/>
            </Grid>
        </Border>

        <!-- ═══ Column 1: Drawer (animated width via inner container) ═══ -->
        <Grid Grid.Column="1" ClipToBounds="True">
            <Border x:Name="DrawerContainer" Width="175" Background="#FF000000">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Logo -->
                    <Border Grid.Row="0" Height="42" Background="#FF000000"
                            BorderThickness="0,0,0,1" BorderBrush="#33FFFFFF">
                        <TextBlock Text="HeliVMS" FontSize="14" FontWeight="Bold"
                                   Foreground="#FFFFFFFF"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Border>
                    <!-- Camera tree (Live mode) -->
                    <controls:CameraTreePanel x:Name="LiveDrawer" Grid.Row="1"/>
                    <!-- Sub-menu drawer (non-Live modes) -->
                    <Border x:Name="SubMenuDrawer" Grid.Row="1" Visibility="Collapsed"
                            Background="#FF000000"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ Column 2: Main Work Area ═══ -->
        <ContentControl x:Name="MainWorkArea" Grid.Column="2"/>

        <!-- Toast Notification -->
        <Border Grid.Column="2" x:Name="ToastOverlay"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,16,0" Visibility="Collapsed"
                Background="#E0000000" CornerRadius="8" Padding="14,10" MaxWidth="360"
                BorderThickness="1" BorderBrush="#33FFFFFF">
            <TextBlock x:Name="ToastText" Text="" FontSize="12" Foreground="#E1E1E1"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>