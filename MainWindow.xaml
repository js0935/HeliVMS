<!-- ============================================================
     HeliVMS - 智慧影像管理系統     禾秝軟體開發團隊 / 代碼設計：洪俊士 / 版本：V1.0.0
     ============================================================ -->
<Window x:Class="HeliVMS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HeliVMS — 智慧影像管理系統"
        Height="768" Width="1024"
        WindowState="Maximized"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Icon="images/HeliNVR.ico"
        Background="{StaticResource BackgroundBrush}"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" x:Name="Sidebar"
                Width="200"
                Background="{StaticResource SidebarBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo / Brand -->
                <Border Grid.Row="0" Height="64" Padding="16,0"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{StaticResource BorderBrush}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="HeliVMS" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="智慧影像管理系統" FontSize="11"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Navigation Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent"
                              BorderThickness="0">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="主要功能" Style="{StaticResource ModernLabel}"
                                   Margin="16,8,16,4"/>

                        <RadioButton x:Name="NavDashboard" GroupName="NavGroup"
                                     Content="系統儀表板" Style="{StaticResource SidebarNavItem}"
                                     IsChecked="True"
                                     Tag="Dashboard" Checked="Nav_Checked"/>
                        <RadioButton x:Name="NavLiveView" GroupName="NavGroup"
                                     Content="即時監看" Style="{StaticResource SidebarNavItem}"
                                     Tag="LiveView" Checked="Nav_Checked"/>
                        <RadioButton x:Name="NavDeviceMgmt" GroupName="NavGroup"
                                     Content="設備管理" Style="{StaticResource SidebarNavItem}"
                                     Tag="DeviceManagement" Checked="Nav_Checked"/>
                        <RadioButton x:Name="NavPlayback" GroupName="NavGroup"
                                     Content="錄影回放" Style="{StaticResource SidebarNavItem}"
                                     Tag="Playback" Checked="Nav_Checked"/>

                        <TextBlock x:Name="SectionSystemMgmt" Text="系統管理" Style="{StaticResource ModernLabel}"
                                   Margin="16,16,16,4"/>

                        <RadioButton x:Name="NavSettings" GroupName="NavGroup"
                                     Content="系統設定" Style="{StaticResource SidebarNavItem}"
                                     Tag="Settings" Checked="Nav_Checked"/>
                        <RadioButton x:Name="NavLicense" GroupName="NavGroup"
                                     Content="授權管理" Style="{StaticResource SidebarNavItem}"
                                     Tag="License" Checked="Nav_Checked"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- User Info / Power Menu -->
                <Border Grid.Row="2" Padding="16,12"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource BorderBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="UserDisplayName" Text="未登入"
                                   FontSize="13" Foreground="{StaticResource TextBrush}"/>

                        <Button x:Name="PowerButton" Grid.Row="1"
                                Content="⏻"
                                Style="{StaticResource SecondaryButton}"
                                Height="32" FontSize="20"
                                Margin="0,6,0,0"
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                Click="PowerButton_Click"/>

                        <!-- Power Menu Popup -->
                        <Popup x:Name="PowerMenuPopup" Grid.Row="1"
                               PlacementTarget="{Binding ElementName=PowerButton}"
                               Placement="Top"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Slide">
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="4"
                                    MinWidth="200">
                                <StackPanel>
                                    <Button x:Name="ExitAppItem" Content="  離開"
                                            Style="{StaticResource PowerMenuItem}"
                                            Click="ExitApp_Click"/>
                                    <Button x:Name="MinimizeItem" Content="  最小化"
                                            Style="{StaticResource PowerMenuItem}"
                                            Click="Minimize_Click"/>
                                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>
                                    <Button x:Name="LogoutItem" Content="  登出"
                                            Style="{StaticResource PowerMenuItem}"
                                            Click="Logout_Click"/>
                                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>
                                    <Button x:Name="AboutItem" Content="  關於"
                                            Style="{StaticResource PowerMenuItem}"
                                            Click="About_Click"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Bottom" Height="24" Padding="8,0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource BorderBrush}">
                    <TextBlock x:Name="StatusBarText"
                               Text=""
                               FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
                </Border>
                <ContentControl x:Name="MainContent"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
            </DockPanel>
        </Border>
        <!-- Toast Notification -->
        <Border x:Name="ToastOverlay" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,16,0" Visibility="Collapsed"
                Background="#E0000000" CornerRadius="8" Padding="14,10" MaxWidth="360"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <TextBlock x:Name="ToastText" Text="" FontSize="12" Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
