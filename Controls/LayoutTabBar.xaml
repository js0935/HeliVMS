<UserControl x:Class="HeliVMS.Controls.LayoutTabBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SurfaceBrush}">
    <Grid Height="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Disabled"
                      HorizontalScrollBarVisibility="Auto">
            <StackPanel x:Name="TabStrip" Orientation="Horizontal"/>
        </ScrollViewer>
        <Button Grid.Column="1" x:Name="BtnAddTab"
                Width="20" Height="20" Margin="4,0,4,0"
                Padding="0" FontSize="14" FontWeight="Bold"
                Style="{StaticResource FlatButton}"
                Foreground="{DynamicResource SecondaryTextBrush}"
                ToolTip="新增佈局分頁"
                Click="BtnAddTab_Click">
            <Path Data="{StaticResource IconPlus}" Fill="{DynamicResource SecondaryTextBrush}" Width="12" Height="12" Stretch="Uniform"/>
        </Button>
    </Grid>
</UserControl>
