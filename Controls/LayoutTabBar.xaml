<UserControl x:Class="HeliVMS.Controls.LayoutTabBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#2A000000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Disabled"
                      HorizontalScrollBarVisibility="Auto">
            <StackPanel x:Name="TabStrip" Orientation="Horizontal"/>
        </ScrollViewer>
        <Button Grid.Column="1" x:Name="BtnAddTab" Content="+" Width="24" Height="24"
                FontSize="16" FontWeight="Bold" Padding="0" Margin="2,0"
                Style="{StaticResource FlatButton}"
                ToolTip="新增佈局分頁"
                Click="BtnAddTab_Click"/>
    </Grid>
</UserControl>
