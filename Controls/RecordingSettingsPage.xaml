<UserControl x:Class="HeliVMS.Controls.RecordingSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">

    <Border Background="{StaticResource BackgroundBrush}" Padding="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ========== Left: Camera List ========== -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header row -->
                    <Border Grid.Row="0" Padding="12,10"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource BorderBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CH" FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="攝影機名稱" FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="錄音" FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontWeight="SemiBold" Margin="0,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Toolbar: batch-toggle + apply-all + save-all -->
                    <Border Grid.Row="1" Padding="8,6"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource SecondarySurfaceBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BatchToggleBtn" Content="批次設定"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="26" FontSize="11" Padding="8,0"
                                    Margin="0,0,4,0"
                                    Click="BatchToggle_Click"/>
                            <Button x:Name="SetAllContinuousBtn" Content="全時預設"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="26" FontSize="11" Padding="8,0"
                                    Margin="4,0,0,0"
                                    Click="SetAllContinuous_Click"/>
                            <Button x:Name="ApplyAllBtn" Content="套用全部"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="26" FontSize="11" Padding="8,0"
                                    Margin="4,0,0,0"
                                    Click="ApplyAll_Click"/>
                            <Button x:Name="SaveAllBtn" Content="儲存全部"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="26" FontSize="11" Padding="8,0"
                                    Margin="4,0,0,0"
                                    Click="SaveAll_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Scrollable camera list -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="Transparent" BorderThickness="0">
                        <StackPanel x:Name="CameraListPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ========== Right: Schedule Grid ========== -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Mode selector toolbar -->
                    <Border Grid.Row="0" Background="{StaticResource SecondarySurfaceBrush}"
                            CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Row 0: Mode selectors -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="繪製模式："
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>

                            <Border Grid.Row="0" Grid.Column="1" x:Name="ModeContinuous" Width="24" Height="24"
                                    CornerRadius="4" Background="#FF2196F3" Cursor="Hand"
                                    Margin="4,0" ToolTip="全時錄影（藍色）"
                                    MouseDown="ModeSelector_MouseDown" Tag="Continuous">
                                <Border x:Name="ModeContinuousBorder" BorderThickness="2"
                                        BorderBrush="Transparent" CornerRadius="4"/>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" x:Name="ModeMotion" Width="24" Height="24"
                                    CornerRadius="4" Background="#FF4CAF50" Cursor="Hand"
                                    Margin="4,0" ToolTip="位移偵測（綠色）"
                                    MouseDown="ModeSelector_MouseDown" Tag="Motion">
                                <Border x:Name="ModeMotionBorder" BorderThickness="2"
                                        BorderBrush="Transparent" CornerRadius="4"/>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="3" x:Name="ModeAlarm" Width="24" Height="24"
                                    CornerRadius="4" Background="#FFF44336" Cursor="Hand"
                                    Margin="4,0" ToolTip="警報錄影（紅色）"
                                    MouseDown="ModeSelector_MouseDown" Tag="Alarm">
                                <Border x:Name="ModeAlarmBorder" BorderThickness="2"
                                        BorderBrush="Transparent" CornerRadius="4"/>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="4" x:Name="ModeSmart" Width="24" Height="24"
                                    CornerRadius="4" Background="#FFE91E63" Cursor="Hand"
                                    Margin="4,0" ToolTip="智慧錄影（粉紅色）"
                                    MouseDown="ModeSelector_MouseDown" Tag="Smart">
                                <Border x:Name="ModeSmartBorder" BorderThickness="2"
                                        BorderBrush="Transparent" CornerRadius="4"/>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="5" x:Name="ModeWeighted" Width="24" Height="24"
                                    CornerRadius="4" Background="#FFFF9800" Cursor="Hand"
                                    Margin="4,0" ToolTip="加權錄影（黃色）"
                                    MouseDown="ModeSelector_MouseDown" Tag="Weighted">
                                <Border x:Name="ModeWeightedBorder" BorderThickness="2"
                                        BorderBrush="Transparent" CornerRadius="4"/>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="6" x:Name="ModeNone" Width="24" Height="24"
                                    CornerRadius="4" Background="{StaticResource InputBackgroundBrush}"
                                    Cursor="Hand" Margin="4,0" ToolTip="清除（無錄影）"
                                    MouseDown="ModeSelector_MouseDown" Tag="None">
                                <Border x:Name="ModeNoneBorder" BorderThickness="2"
                                        BorderBrush="Transparent" CornerRadius="4"/>
                            </Border>

                            <!-- Audio checkbox -->
                            <StackPanel Grid.Row="0" Grid.Column="7" Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <CheckBox x:Name="AudioCheckBox" Content="啟用錄音"
                                          FontSize="12" Foreground="{StaticResource TextBrush}"
                                          Checked="AudioCheckBox_Changed"
                                          Unchecked="AudioCheckBox_Changed"/>
                            </StackPanel>

                            <!-- Row 1: Mode descriptions legend -->
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="8" Orientation="Horizontal"
                                        Margin="0,6,0,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                    <TextBlock Text="■" FontSize="11" Foreground="#FF2196F3" Margin="0,0,4,0"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource SecondaryTextBrush}">
                                        <Run Foreground="#FF2196F3" Text="全時錄影"/>
                                        <Run Text="：24小時不間斷錄影"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                    <TextBlock Text="■" FontSize="11" Foreground="#FF4CAF50" Margin="0,0,4,0"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource SecondaryTextBrush}">
                                        <Run Foreground="#FF4CAF50" Text="位移錄影"/>
                                        <Run Text="：當畫面變動時錄影"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                    <TextBlock Text="■" FontSize="11" Foreground="#FFF44336" Margin="0,0,4,0"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource SecondaryTextBrush}">
                                        <Run Foreground="#FFF44336" Text="警報錄影"/>
                                        <Run Text="：由DI感應器觸發錄影"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                    <TextBlock Text="■" FontSize="11" Foreground="#FFE91E63" Margin="0,0,4,0"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource SecondaryTextBrush}">
                                        <Run Foreground="#FFE91E63" Text="智能錄影"/>
                                        <Run Text="：當畫面沒有變動時每秒1張，當畫面變動時每秒30張"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                    <TextBlock Text="■" FontSize="11" Foreground="#FFFF9800" Margin="0,0,4,0"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource SecondaryTextBrush}">
                                        <Run Foreground="#FFFF9800" Text="加權錄影"/>
                                        <Run Text="：位移前5秒至後5秒"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="□" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="不錄影" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Row 2: Quick presets -->
                            <StackPanel Grid.Row="2" Grid.ColumnSpan="8" Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="快速套用：" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,6,0"/>
                                <Button x:Name="PresetDaytime" Content="白天" Width="50" Height="24" FontSize="11"
                                        Style="{StaticResource SecondaryButton}" Padding="4,0" Margin="2,0"
                                        Tag="06-18" Click="QuickPreset_Click"/>
                                <Button x:Name="PresetNight" Content="夜晚" Width="50" Height="24" FontSize="11"
                                        Style="{StaticResource SecondaryButton}" Padding="4,0" Margin="2,0"
                                        Tag="18-06" Click="QuickPreset_Click"/>
                                <Button x:Name="PresetHoliday" Content="假日" Width="50" Height="24" FontSize="11"
                                        Style="{StaticResource SecondaryButton}" Padding="4,0" Margin="2,0"
                                        Tag="weekend" Click="QuickPreset_Click"/>
                                <Button x:Name="PresetFullDay" Content="全天" Width="50" Height="24" FontSize="11"
                                        Style="{StaticResource SecondaryButton}" Padding="4,0" Margin="2,0"
                                        Tag="00-24" Click="QuickPreset_Click"/>
                                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                           Margin="4,0" Height="16"/>
                                <Button x:Name="PresetClearAll" Content="清除全部" Width="70" Height="24" FontSize="11"
                                        Style="{StaticResource SecondaryButton}" Padding="4,0" Margin="2,0"
                                        Tag="clear" Click="QuickPreset_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Selected camera name -->
                    <TextBlock Grid.Row="1" x:Name="SelectedCameraName"
                               Text="請選擇左側攝影機以編輯排程"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <!-- 7x24 grid -->
                    <Border Grid.Row="2" CornerRadius="6" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource InputBackgroundBrush}"
                            Padding="4">
                        <ScrollViewer x:Name="ScheduleScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <Grid x:Name="ScheduleGrid" Margin="4"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
