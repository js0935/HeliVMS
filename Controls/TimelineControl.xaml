<UserControl x:Class="HeliVMS.Controls.TimelineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HeliVMS.Controls">
    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="4">
        <Grid>
            <ScrollViewer x:Name="TimelineScroller"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PanningMode="Both"
                          Background="Transparent"
                          ScrollChanged="TimelineScroller_ScrollChanged">
                <local:TimelineCanvas x:Name="TimelineCanvas"
                        ClipToBounds="True"
                        Background="Transparent"
                        MouseDown="TimelineCanvas_MouseDown"
                        MouseMove="TimelineCanvas_MouseMove"
                        MouseUp="TimelineCanvas_MouseUp"
                        PreviewMouseWheel="TimelineCanvas_PreviewMouseWheel"
                        MouseLeave="TimelineCanvas_MouseLeave"
                        SizeChanged="TimelineCanvas_SizeChanged"/>
            </ScrollViewer>
            <StackPanel x:Name="ZoomPresetPanel"
                        VerticalAlignment="Bottom" HorizontalAlignment="Right"
                        Orientation="Horizontal" Margin="0,0,8,4">
                <Button x:Name="Zoom1H" Content="1H"
                        Style="{StaticResource SecondaryButton}"
                        Height="18" Width="26" FontSize="8" Padding="0"
                        Margin="0,0,2,0" Click="ZoomPreset_Click"
                        Tag="1"/>
                <Button x:Name="Zoom6H" Content="6H"
                        Style="{StaticResource SecondaryButton}"
                        Height="18" Width="26" FontSize="8" Padding="0"
                        Margin="0,0,2,0" Click="ZoomPreset_Click"
                        Tag="6"/>
                <Button x:Name="Zoom12H" Content="12H"
                        Style="{StaticResource SecondaryButton}"
                        Height="18" Width="26" FontSize="8" Padding="0"
                        Margin="0,0,2,0" Click="ZoomPreset_Click"
                        Tag="12"/>
                <Button x:Name="Zoom24H" Content="24H"
                        Style="{StaticResource SecondaryButton}"
                        Height="18" Width="26" FontSize="8" Padding="0"
                        Margin="0,0,4,0" Click="ZoomPreset_Click"
                        Tag="24"/>
                <Border Background="{DynamicResource OverlayBrush}" CornerRadius="3"
                        Padding="6,2" VerticalAlignment="Center">
                    <TextBlock x:Name="ZoomLevelText" Text="24H"
                                FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
