<UserControl x:Class="HeliVMS.Controls.NxTimeline"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SurfaceBrush}"
             BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}" Opacity="0.5">
            <Canvas x:Name="CameraRowsCanvas" Background="Transparent"
                    PreviewMouseWheel="Canvas_PreviewMouseWheel"
                    PreviewMouseRightButtonDown="Canvas_PreviewMouseRightButtonDown"
                    PreviewMouseRightButtonUp="Canvas_PreviewMouseRightButtonUp"
                    PreviewMouseMove="Canvas_PreviewMouseMove"
                    PreviewMouseLeftButtonDown="Canvas_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="Canvas_PreviewMouseLeftButtonUp"
                    ClipToBounds="True">
                <Canvas.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="放大至選區" InputGestureText="Ctrl+Wheel" Click="CtxZoomToSel"/>
                        <MenuItem Header="清除選取" InputGestureText="Esc" Click="CtxClearSel"/>
                        <Separator/>
                        <MenuItem Header="匯出選取區段" InputGestureText="Ctrl+E" Click="CtxExportRange"/>
                        <MenuItem Header="加入書籤" InputGestureText="B" Click="CtxAddBookmark"/>
                    </ContextMenu>
                </Canvas.ContextMenu>
            </Canvas>
        </Border>
        <Border Grid.Row="1" Background="{DynamicResource BackgroundBrush}" Opacity="0.5">
            <Canvas x:Name="TimeScaleCanvas" ClipToBounds="True"
                    PreviewMouseWheel="Scale_PreviewMouseWheel"
                    MouseDown="Scale_MouseDown"/>
        </Border>
        <Canvas x:Name="SelectionCanvas" IsHitTestVisible="False" ClipToBounds="True"
                Grid.RowSpan="2"/>
        <Canvas x:Name="PositionCanvas" IsHitTestVisible="False" ClipToBounds="True"
                Grid.RowSpan="2"/>
        <Canvas x:Name="BookmarksCanvas" IsHitTestVisible="False" ClipToBounds="True"
                Grid.RowSpan="2"/>
        <TextBlock x:Name="ZoomLabel" Grid.Row="1" Text="24h"
                   FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"
                   HorizontalAlignment="Right" VerticalAlignment="Center"
                   Margin="0,0,4,0" IsHitTestVisible="False"/>
        <Button x:Name="GoLiveBtn" Grid.Row="0" Content="現在"
                FontSize="9" Padding="6,1" Height="18"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,2,4,0" Cursor="Hand"
                Background="{DynamicResource OverlayBrush}" Foreground="{DynamicResource TextBrush}"
                BorderThickness="0" Click="GoLiveBtn_Click"/>
    </Grid>
</UserControl>
