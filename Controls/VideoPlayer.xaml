<UserControl x:Class="HeliVMS.Controls.VideoPlayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource SurfaceBrush}">
    <UserControl.ContextMenu>
        <ContextMenu Background="{DynamicResource SurfaceBrush}"
                     BorderBrush="{DynamicResource BorderBrush}">
            <ContextMenu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                </Style>
            </ContextMenu.Resources>
            <MenuItem x:Name="CtxSnapshot" Header="拍照" InputGestureText="Ctrl+P" Click="CtxSnapshot_Click">
                <MenuItem.Icon>
                    <Path Data="{StaticResource IconSnapshot}" Fill="{DynamicResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="CtxFullscreen" Header="全畫面" InputGestureText="F11" Click="CtxFullscreen_Click">
                <MenuItem.Icon>
                    <Path Data="{StaticResource IconFullScreen}" Fill="{DynamicResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="CtxStreamToggle" Header="切換串流" Click="CtxStreamToggle_Click">
                <MenuItem.Icon>
                    <Path Data="{StaticResource IconCamera}" Fill="{DynamicResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator Background="{DynamicResource BorderBrush}"/>
            <MenuItem x:Name="CtxBookmark" Header="加入書籤" InputGestureText="B" Click="CtxBookmark_Click">
                <MenuItem.Icon>
                    <Path Data="{StaticResource IconBookmark}" Fill="{DynamicResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="CtxRecordingToggle" Header="開始錄影" Click="CtxRecordingToggle_Click">
                <MenuItem.Icon>
                    <Path Data="{StaticResource IconRecording}" Fill="{DynamicResource ErrorBrush}" Width="14" Height="14" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator Background="{DynamicResource BorderBrush}"/>
            <MenuItem x:Name="CtxPtzSelect" Header="PTZ 控制此攝影機" Click="CtxPtzSelect_Click">
                <MenuItem.Icon>
                    <Path Data="{StaticResource IconPtz}" Fill="{DynamicResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.ContextMenu>

    <Border x:Name="PlayerBorder"
             BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="4">
            <Border.Effect>
                <DropShadowEffect x:Name="GlowEffect"
                                  BlurRadius="15"
                                  ShadowDepth="0"
                                  Opacity="0"/>
        </Border.Effect>
        <Grid x:Name="RootGrid"
              Background="Transparent"
              MouseDown="RootGrid_MouseDown"
              MouseMove="RootGrid_MouseMove"
              MouseUp="RootGrid_MouseUp"
              MouseWheel="RootGrid_MouseWheel"
              MouseRightButtonUp="RootGrid_MouseRightButtonUp"
              MouseEnter="RootGrid_MouseEnter"
              MouseLeave="RootGrid_MouseLeave">

            <!-- Recording mode indicator dot (top-right) -->
            <Ellipse x:Name="RecordingModeDot"
                     Width="10" Height="10"
                     Fill="Transparent"
                     VerticalAlignment="Top" HorizontalAlignment="Right"
                     Margin="0,10,40,0"
                      Stroke="{DynamicResource OverlayBrush}" StrokeThickness="1"
                     Visibility="Collapsed"
                     ToolTip="錄影模式"/>

            <!-- Stream toggle button (top-right) -->
            <Button x:Name="StreamToggle"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="8" Padding="0"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand"
                    Visibility="Collapsed"
                    Click="StreamToggle_Click">
                <Border Background="{DynamicResource OverlayBrush}" CornerRadius="3" Padding="6,2">
                    <TextBlock x:Name="StreamToggleText" Text="HD"
                               FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                </Border>
            </Button>

            <!-- PTZ floating overlay (bottom-right) -->
            <Border x:Name="PtzOverlay" Panel.ZIndex="11"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Margin="8" Padding="4"
                    Background="{DynamicResource OverlayBrush}" CornerRadius="4"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="PtzUp" Width="26" Height="26" Padding="0"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="上"
                            Click="PtzUp_Click">
                        <Path Data="{StaticResource IconChevronUp}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="PtzDown" Width="26" Height="26" Padding="0"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="下"
                            Click="PtzDown_Click">
                        <Path Data="{StaticResource IconChevronDown}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="PtzLeft" Width="26" Height="26" Padding="0"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="左"
                            Click="PtzLeft_Click">
                        <Path Data="{StaticResource IconChevronLeft}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="PtzRight" Width="26" Height="26" Padding="0"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="右"
                            Click="PtzRight_Click">
                        <Path Data="{StaticResource IconChevronRight}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="PtzZoomIn" Width="26" Height="26" Padding="0"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="放大"
                            Click="PtzZoomIn_Click">
                        <Path Data="{StaticResource IconPlus}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="PtzZoomOut" Width="26" Height="26" Padding="0"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="縮小"
                            Click="PtzZoomOut_Click">
                        <Path Data="{StaticResource IconMinus}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Nx-style bottom info bar (full-width) -->
            <Border x:Name="NameTag" Panel.ZIndex="10"
                    VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                    Height="26"
                    Background="{DynamicResource OverlayBrush}"
                    IsHitTestVisible="False">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="CameraNameText"
                                   Text="" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock x:Name="HealthBadge"
                                   Margin="6,0,0,0"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="RecTimeText" Text="" FontSize="10"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Visibility="Collapsed" Margin="0,0,4,0"/>
                        <Ellipse x:Name="RecIndicator" Width="8" Height="8"
                                 Fill="{DynamicResource ErrorBrush}"
                                 Visibility="Collapsed" Margin="0,0,4,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Hover overlay (fade in/out on mouse enter/leave) -->
            <Grid x:Name="OverlayGrid" Panel.ZIndex="20"
                  Visibility="Collapsed" Background="Transparent">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Top" HorizontalAlignment="Right"
                            Margin="6">
                    <Border Background="{DynamicResource OverlayBrush}" CornerRadius="3" Margin="2,0">
                        <Button x:Name="SnapshotBtn"
                                Width="28" Height="28" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand"
                                Click="SnapshotBtn_Click">
                            <Path Data="{StaticResource IconSnapshot}" Fill="{DynamicResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                    </Border>
                    <Border Background="{DynamicResource OverlayBrush}" CornerRadius="3" Margin="2,0">
                        <Button x:Name="CloseBtn"
                                Width="28" Height="28" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand"
                                Click="CloseBtn_Click">
                            <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Flyleaf hardware-accelerated video (primary) — created programmatically when engine is ready -->


            <!-- Decoder stream frame fallback (in-process FFmpeg) -->
            <Image x:Name="DecoderFrameImage" Visibility="Collapsed"
                   Stretch="UniformToFill"
                   RenderTransformOrigin="0.5,0.5"
                   Panel.ZIndex="1">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="DecoderZoomScale" />
                        <TranslateTransform x:Name="DecoderZoomTranslate" />
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>

            <!-- Reconnecting overlay (on frozen frame) -->
            <Border x:Name="ReconnectingOverlay" Panel.ZIndex="12"
                    Background="{DynamicResource OverlayBrush}"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="重新連線中..." Foreground="{DynamicResource TextBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ReconnectAttemptText" Text=""
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Offline / disconnected placeholder -->
            <Border x:Name="Placeholder" Background="{DynamicResource SecondarySurfaceBrush}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Path Data="{StaticResource IconCamera}" Fill="{DynamicResource SecondaryTextBrush}" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CameraNameTextPlaceholder"
                               Text="攝影機名稱"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               Margin="0,8,0,2"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="StatusText"
                               Text="未連線"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Digital zoom HUD -->
            <TextBlock x:Name="DecoderZoomHud"
                       FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,30"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"/>

            <!-- Decode info OSD (FPS / resolution) -->
            <Border x:Name="InfoOSD" Panel.ZIndex="15"
                    VerticalAlignment="Bottom" HorizontalAlignment="Left"
                    Margin="6,0,0,6" Padding="6,2"
                    Background="{DynamicResource OverlayBrush}" CornerRadius="3"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                <TextBlock x:Name="InfoOSText" Text=""
                           FontSize="10" FontWeight="Normal"
                           Foreground="{DynamicResource TextBrush}"/>
            </Border>
        </Grid>
    </Border>
</UserControl>