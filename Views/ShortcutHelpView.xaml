<UserControl x:Class="HeliVMS.Views.ShortcutHelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#E0000000">
    <Border Background="#1E1E1E" CornerRadius="12" BorderThickness="1" BorderBrush="#33FFFFFF"
            Width="400" Padding="24">
        <StackPanel>
            <TextBlock Text="鍵盤快捷鍵" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="F / F11" FontSize="12" FontWeight="SemiBold"
                           Foreground="#FF4CAF50" Margin="0,0,16,8"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="切換全螢幕" FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Esc" FontSize="12" FontWeight="SemiBold"
                           Foreground="#FF4CAF50" Margin="0,0,16,8"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="退出全螢幕" FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+R" FontSize="12" FontWeight="SemiBold"
                           Foreground="#FF4CAF50" Margin="0,0,16,8"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="切換選取攝影機錄影" FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl+Shift+?" FontSize="12" FontWeight="SemiBold"
                           Foreground="#FF4CAF50" Margin="0,0,16,8"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="顯示此說明" FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8"/>
            </Grid>
            <Button Content="關閉" Width="80" Height="28" FontSize="11"
                    Style="{StaticResource ModernButton}" Margin="0,16,0,0"
                    Click="Close_Click"/>
        </StackPanel>
    </Border>
</UserControl>
