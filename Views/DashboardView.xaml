<UserControl x:Class="HeliVMS.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="24">
        <StackPanel>
            <TextBlock Text="系統儀表板" Style="{StaticResource PageHeader}"/>

            <!-- Top status cards row (Nx-style) -->
            <WrapPanel Margin="0,0,-12,0">
                <!-- Camera Status -->
                <Border Style="{StaticResource CardBorder}" MinWidth="180"
                        Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Data="{StaticResource IconCamera}"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="攝影機狀態" Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="CameraOnlineText" Text="—" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}"/>
                                <TextBlock Text="上線中" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="CameraOfflineText" Text="—" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ErrorBrush}"/>
                                <TextBlock Text="離線" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Recording Status -->
                <Border Style="{StaticResource CardBorder}" MinWidth="180"
                        Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Data="{StaticResource IconRecording}"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="錄影狀態" Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="RecordingCountText" Text="—" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock x:Name="StorageUsageText" Text="" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <!-- System Resources -->
                <Border Style="{StaticResource CardBorder}" MinWidth="180"
                        Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Data="{StaticResource IconSettings}"
                                  Fill="{DynamicResource TextBrush}"
                                  Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="系統資源" Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="CpuUsageText" Text="—" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="CPU" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                        <TextBlock x:Name="MemoryUsageText" Text="" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock x:Name="DiskUsageText" Text="" FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock x:Name="BandwidthText" Text="" FontSize="11" Margin="0,2,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Health Score -->
                <Border Style="{StaticResource CardBorder}" MinWidth="180"
                        Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Data="{StaticResource IconStar}"
                                  Fill="{DynamicResource WarningBrush}"
                                  Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="系統健康評分" Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="HealthScoreText" Text="—" FontSize="36" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="/ 100" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,-4,0,0"/>
                        <WrapPanel Margin="0,8,0,0">
                            <TextBlock x:Name="HealthDetailOnline" Text="" FontSize="11"
                                       Foreground="{DynamicResource SuccessBrush}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="HealthDetailRecording" Text="" FontSize="11"
                                       Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="HealthDetailStorage" Text="" FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Storage -->
                <Border Style="{StaticResource CardBorder}" MinWidth="180"
                        Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Data="{StaticResource IconSave}"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="儲存空間" Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="StorageTotalText" Text="—" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock x:Name="StorageUsedPercentText" Text="" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <Border x:Name="StorageBarBg" Height="6" CornerRadius="3" Margin="0,6,0,0"
                                Background="{DynamicResource SecondarySurfaceBrush}">
                            <Border x:Name="StorageBarFill" Width="0" Height="6" CornerRadius="3"
                                    HorizontalAlignment="Left" Background="{DynamicResource PrimaryBrush}"/>
                        </Border>
                        <TextBlock x:Name="StorageBreakdownText" Text="" FontSize="11" Margin="0,6,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Recording Success -->
                <Border Style="{StaticResource CardBorder}" MinWidth="180"
                        Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Data="{StaticResource IconBookmark}"
                                  Fill="{DynamicResource SuccessBrush}"
                                  Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="錄影成功率" Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="RecordingSuccessText" Text="—" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock x:Name="RecordingSuccessDetail" Text="" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock x:Name="RecordingFailoverText" Text="" FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Alerts -->
                <Border Style="{StaticResource CardBorder}" MinWidth="180"
                        Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Data="{StaticResource IconBell}"
                                  Fill="{DynamicResource WarningBrush}"
                                  Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="今日警示統計" Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <WrapPanel>
                            <StackPanel Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse Width="6" Height="6" Fill="{DynamicResource ErrorBrush}"
                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="錯誤" FontSize="11"
                                               Foreground="{DynamicResource ErrorBrush}" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock x:Name="AlertCountText" Text="0" FontSize="24" FontWeight="Bold"
                                           Foreground="{DynamicResource ErrorBrush}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse Width="6" Height="6" Fill="{DynamicResource WarningBrush}"
                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="警告" FontSize="11"
                                               Foreground="{DynamicResource WarningBrush}" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock x:Name="WarningCountText" Text="0" FontSize="24" FontWeight="Bold"
                                           Foreground="{DynamicResource WarningBrush}"/>
                            </StackPanel>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse Width="6" Height="6" Fill="{DynamicResource PrimaryBrush}"
                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="資訊" FontSize="11"
                                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock x:Name="InfoCountText" Text="0" FontSize="24" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryBrush}"/>
                            </StackPanel>
                        </WrapPanel>
                        <TextBlock x:Name="AlertStatsText" Text="" FontSize="11" Margin="0,8,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Camera health list -->
            <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Path Data="{StaticResource IconCamera}"
                              Fill="{DynamicResource TextBrush}"
                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="攝影機健康狀態" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="最近 30 分鐘內的連線狀態" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="CameraHealthList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource DividerBrush}" Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="8" Height="8"
                                                 Fill="{Binding StatusBrush}"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding LastError}" FontSize="11"
                                                   Foreground="{DynamicResource ErrorBrush}" Margin="0,0,12,0"
                                                   VerticalAlignment="Center" MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding LastConnectedAt, StringFormat={}{0:MM/dd HH:mm}}"
                                                   FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Charts row -->
            <WrapPanel Margin="0,0,-12,16">
                <Border Style="{StaticResource CardBorder}" MinWidth="340" Margin="0,0,12,12" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource PrimaryBrush}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="頻寬趨勢（最近 60 分鐘）" Style="{StaticResource SectionHeader}"/>
                        </StackPanel>
                        <Canvas x:Name="BandwidthChartCanvas" Width="340" Height="120" ClipToBounds="True"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" MinWidth="340" Margin="0,0,12,12" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="儲存使用趨勢（最近 24 小時）" Style="{StaticResource SectionHeader}"/>
                        </StackPanel>
                        <Canvas x:Name="StorageChartCanvas" Width="340" Height="120" ClipToBounds="True"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" MinWidth="340" Margin="0,0,12,12" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource WarningBrush}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="CPU 使用率（最近 60 分鐘）" Style="{StaticResource SectionHeader}"/>
                        </StackPanel>
                        <Canvas x:Name="CpuChartCanvas" Width="340" Height="120" ClipToBounds="True"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" MinWidth="340" Margin="0,0,12,12" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource ErrorBrush}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="記憶體使用率（最近 60 分鐘）" Style="{StaticResource SectionHeader}"/>
                        </StackPanel>
                        <Canvas x:Name="MemoryChartCanvas" Width="340" Height="120" ClipToBounds="True"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Recording calendar -->
            <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconCalendar}"
                                  Fill="{DynamicResource TextBrush}"
                                  Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="錄影日曆" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="CalendarPrevBtn"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="24" Width="28" FontSize="10" Padding="0"
                                    Click="CalendarPrevBtn_Click">
                                <Path Data="{StaticResource IconChevronLeft}" Fill="{DynamicResource TextBrush}" Width="10" Height="10" Stretch="Uniform"/>
                            </Button>
                            <TextBlock x:Name="CalendarMonthText" Text="----年--月"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <Button x:Name="CalendarNextBtn"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="24" Width="28" FontSize="10" Padding="0"
                                    Click="CalendarNextBtn_Click">
                                <Path Data="{StaticResource IconChevronRight}" Fill="{DynamicResource TextBrush}" Width="10" Height="10" Stretch="Uniform"/>
                            </Button>
                            <Button x:Name="CalendarTodayBtn" Content="今天"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="24" FontSize="10" Padding="6,0"
                                    Margin="6,0,0,0"
                                    Click="CalendarTodayBtn_Click"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="CalendarLoadingText" Text="載入中…"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11" Visibility="Collapsed"/>
                    <Border x:Name="CalendarGridContainer" MinHeight="200"/>
                </StackPanel>
            </Border>

            <!-- Recent events -->
            <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Path Data="{StaticResource IconWarning}"
                              Fill="{DynamicResource TextBrush}"
                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="近期系統事件" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DataGrid x:Name="RecentEventsGrid"
                              Style="{StaticResource ModernDataGrid}"
                              AutoGenerateColumns="False"
                              CanUserResizeRows="False"
                              MaxHeight="320"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              ColumnHeaderStyle="{StaticResource ModernColumnHeader}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="時間" Binding="{Binding Timestamp, StringFormat=\{0:HH:mm:ss\}}" Width="70"/>
                            <DataGridTextColumn Header="層級" Binding="{Binding Severity}" Width="50"/>
                            <DataGridTextColumn Header="來源" Binding="{Binding Source}" Width="100"/>
                            <DataGridTextColumn Header="訊息" Binding="{Binding Message}" Width="*" MinWidth="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
