<UserControl x:Class="HeliVMS.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="24">
        <StackPanel>
            <TextBlock Text="系統儀表板" Style="{StaticResource PageHeader}"/>

            <!-- Status cards row -->
            <WrapPanel Margin="0,0,0,16">
                <Border Style="{StaticResource CardBorder}" MinWidth="180" Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="攝影機狀態" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="CameraOnlineText" Text="—" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"/>
                        <TextBlock Text="上線中" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock x:Name="CameraOfflineText" Text="—" FontSize="14" Margin="0,8,0,0"
                                   Foreground="{StaticResource ErrorBrush}"/>
                        <TextBlock Text="離線" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" MinWidth="180" Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="錄影狀態" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="RecordingCountText" Text="—" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="路錄影中" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock x:Name="StorageUsageText" Text="" FontSize="12" Margin="0,8,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" MinWidth="180" Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="系統資源" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="CpuUsageText" Text="—" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="CPU" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock x:Name="MemoryUsageText" Text="" FontSize="12" Margin="0,8,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock x:Name="DiskUsageText" Text="" FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock x:Name="BandwidthText" Text="" FontSize="12" Margin="0,4,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" MinWidth="180" Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="系統健康評分" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="HealthScoreText" Text="—" FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"/>
                        <TextBlock Text="/ 100" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,-4,0,0"/>
                        <WrapPanel Margin="0,8,0,0">
                            <TextBlock x:Name="HealthDetailOnline" Text="" FontSize="11"
                                       Foreground="{StaticResource SuccessBrush}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="HealthDetailRecording" Text="" FontSize="11"
                                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="HealthDetailStorage" Text="" FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" MinWidth="180" Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="儲存空間" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="StorageTotalText" Text="—" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock x:Name="StorageUsedPercentText" Text="" FontSize="12" Margin="0,4,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <Border x:Name="StorageBarBg" Height="8" CornerRadius="4" Margin="0,6,0,0"
                                Background="#333333">
                            <Border x:Name="StorageBarFill" Width="0" Height="8" CornerRadius="4"
                                    HorizontalAlignment="Left" Background="{StaticResource PrimaryBrush}"/>
                        </Border>
                        <TextBlock x:Name="StorageBreakdownText" Text="" FontSize="11" Margin="0,6,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" MinWidth="180" Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="錄影成功率" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="RecordingSuccessText" Text="—" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"/>
                        <TextBlock x:Name="RecordingSuccessDetail" Text="" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock x:Name="RecordingFailoverText" Text="" FontSize="11"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" MinWidth="180" Margin="0,0,12,12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="今日警示統計" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="{Binding ElementName=AlertStatsText, Path=Text}" FontSize="11"
                                           Foreground="{StaticResource ErrorBrush}" FontWeight="Bold"/>
                                <TextBlock x:Name="AlertCountText" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource ErrorBrush}"/>
                                <TextBlock Text="錯誤" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="警告" FontSize="11"
                                           Foreground="{StaticResource WarningBrush}" FontWeight="Bold"/>
                                <TextBlock x:Name="WarningCountText" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource WarningBrush}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="資訊" FontSize="11"
                                           Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold"/>
                                <TextBlock x:Name="InfoCountText" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </WrapPanel>
                        <TextBlock x:Name="AlertStatsText" Text="" FontSize="11" Margin="0,8,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Camera health list -->
            <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="攝影機健康狀態" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                    <TextBlock Text="最近 30 分鐘內的連線狀態" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="CameraHealthList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource DividerBrush}" Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="11" FontWeight="Bold"
                                                   Foreground="{StaticResource SuccessBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding LastError}" FontSize="11"
                                                   Foreground="{StaticResource ErrorBrush}" Margin="0,0,12,0" VerticalAlignment="Center" MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding LastConnectedAt, StringFormat={}{0:MM/dd HH:mm}}"
                                                   FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Historical charts -->
            <WrapPanel Margin="0,0,0,16">
                <Border Style="{StaticResource CardBorder}" MinWidth="360" Margin="0,0,12,12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="頻寬趨勢（最近 60 分鐘）" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <Canvas x:Name="BandwidthChartCanvas" Width="340" Height="120" ClipToBounds="True"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" MinWidth="360" Margin="0,0,12,12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="儲存使用趨勢（最近 24 小時）" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <Canvas x:Name="StorageChartCanvas" Width="340" Height="120" ClipToBounds="True"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" MinWidth="360" Margin="0,0,12,12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="CPU 使用率（最近 60 分鐘）" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <Canvas x:Name="CpuChartCanvas" Width="340" Height="120" ClipToBounds="True"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" MinWidth="360" Margin="0,0,12,12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="記憶體使用率（最近 60 分鐘）" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <Canvas x:Name="MemoryChartCanvas" Width="340" Height="120" ClipToBounds="True"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Recording calendar -->
            <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="錄影日曆" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="CalendarPrevBtn" Content="◀"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="24" Width="28" FontSize="10" Padding="0"
                                    Click="CalendarPrevBtn_Click"/>
                            <TextBlock x:Name="CalendarMonthText" Text="----年--月"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <Button x:Name="CalendarNextBtn" Content="▶"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="24" Width="28" FontSize="10" Padding="0"
                                    Click="CalendarNextBtn_Click"/>
                            <Button x:Name="CalendarTodayBtn" Content="今天"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="24" FontSize="10" Padding="6,0"
                                    Margin="6,0,0,0"
                                    Click="CalendarTodayBtn_Click"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="CalendarLoadingText" Text="載入中…"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11" Visibility="Collapsed"/>
                    <Border x:Name="CalendarGridContainer" MinHeight="200"/>
                </StackPanel>
            </Border>

        <!-- Recent events -->
            <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="近期系統事件" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                    <DataGrid x:Name="RecentEventsGrid"
                              Style="{StaticResource ModernDataGrid}"
                              AutoGenerateColumns="False"
                              CanUserResizeRows="False"
                              MaxHeight="320"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              ColumnHeaderStyle="{StaticResource ModernColumnHeader}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="時間" Binding="{Binding Timestamp, StringFormat=\{0:HH:mm:ss\}}" Width="70"/>
                            <DataGridTextColumn Header="層級" Binding="{Binding Severity}" Width="50"/>
                            <DataGridTextColumn Header="來源" Binding="{Binding Source}" Width="100"/>
                            <DataGridTextColumn Header="訊息" Binding="{Binding Message}" Width="*" MinWidth="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
