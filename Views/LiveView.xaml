<UserControl x:Class="HeliVMS.Views.LiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HeliVMS.Controls"
             Background="{DynamicResource BackgroundBrush}"
             PreviewKeyDown="OnPreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <controls:LayoutTabBar x:Name="TabBar" Grid.Row="0"/>
        <controls:DynamicCameraGrid x:Name="VideoGrid" Grid.Row="1"/>

        <!-- Bottom Control Bar (Nx Witness style) -->
        <Border x:Name="ControlBar" Grid.Row="1" VerticalAlignment="Bottom" Height="32"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Layout selector -->
                <Button x:Name="BtnLayoutToggle" Grid.Column="0"
                        Width="28" Height="24" Padding="0"
                        Style="{StaticResource FlatButton}"
                        Click="LayoutToggle_Click"
                        ToolTip="版面配置">
                    <Grid>
                        <Path Data="{StaticResource IconLayout}" Fill="{DynamicResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        <TextBlock x:Name="LayoutLabel" Text="4"
                                   FontSize="8" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,1,0,0"/>
                    </Grid>
                </Button>

                <!-- Layout popup (drag grid) -->
                <Popup x:Name="LayoutPopup" Grid.Column="0"
                       PlacementTarget="{Binding ElementName=BtnLayoutToggle}"
                       Placement="Top" StaysOpen="False"
                       PopupAnimation="Fade" AllowsTransparency="True">
                    <Border Background="{DynamicResource SidebarBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="8">
                        <StackPanel>
                            <Grid x:Name="LayoutDragGrid" Width="160" Height="160"
                                  MouseMove="LayoutDragGrid_MouseMove"
                                  MouseLeave="LayoutDragGrid_MouseLeave"
                                  MouseDown="LayoutDragGrid_MouseDown"
                                  Background="Transparent"/>
                            <TextBlock x:Name="LayoutSizeLabel"
                                       Text="4"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Save layout -->
                <Button x:Name="BtnSaveLayout" Grid.Column="1"
                        Width="24" Height="24" Padding="0" Margin="4,0,0,0"
                        Style="{StaticResource FlatButton}"
                        ToolTip="儲存目前版面配置"
                        Click="BtnSaveLayout_Click">
                    <Path Data="{StaticResource IconSave}" Fill="{DynamicResource SecondaryTextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                </Button>

                <!-- PTZ control (center) -->
                <StackPanel x:Name="PtzBar" Grid.Column="2"
                            Orientation="Horizontal" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <Button x:Name="BtnPtz"
                            Height="22" Padding="6,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="BtnPtz_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0">
                                <Path Data="{StaticResource IconPtz}" Fill="{DynamicResource SecondaryTextBrush}"/>
                            </Viewbox>
                            <TextBlock Text="PTZ" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="PtzLabel" Text="" FontSize="11" Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Fullscreen -->
                <Button Grid.Column="3"
                        Width="24" Height="24" Padding="0"
                        Style="{StaticResource FlatButton}"
                        ToolTip="全畫面"
                        Click="FullScreen_Click">
                    <Path Data="{StaticResource IconFullScreen}" Fill="{DynamicResource SecondaryTextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
