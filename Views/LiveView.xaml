<UserControl x:Class="HeliVMS.Views.LiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HeliVMS.Controls"
             Background="{StaticResource BackgroundBrush}"
             PreviewKeyDown="OnPreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <controls:LayoutTabBar x:Name="TabBar" Grid.Row="0"/>
        <controls:DynamicCameraGrid x:Name="VideoGrid" Grid.Row="1"/>

        <!-- Camera search filter -->
        <TextBox x:Name="CameraFilterBox" Grid.Row="1"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Width="200" Height="26" Margin="0,8,8,0"
                 FontSize="12" Padding="6,2"
                 Background="{StaticResource OverlayBrush}" Foreground="{StaticResource TextBrush}"
                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                 Panel.ZIndex="30"
                 TextChanged="CameraFilterBox_TextChanged">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Background" Value="{StaticResource OverlayBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Background" Value="{StaticResource OverlayBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>
        <TextBlock Text="搜尋攝影機" FontSize="10"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   Margin="0,13,216,0" Panel.ZIndex="31"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   IsHitTestVisible="False">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Text, ElementName=CameraFilterBox}" Value=""/>
                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=CameraFilterBox}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Timeline Container (floating overlay) -->
        <Border x:Name="TimelineContainer" Grid.Row="1"
                VerticalAlignment="Bottom"
                Height="64" Margin="10,0,10,36"
                Background="{StaticResource SidebarBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BorderBrush}">
            <Grid Margin="4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <Button x:Name="BtnPlayPause"
                            Width="30" Height="28" Padding="0"
                            Style="{StaticResource FlatButton}"
                            Click="BtnPlayPause_Click">
                        <Viewbox Width="14" Height="14" Stretch="Uniform">
                            <Path Data="{StaticResource IconPlay}" Fill="{StaticResource SecondaryTextBrush}"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="BtnSkipBack"
                            Width="28" Height="28" Padding="0"
                            Style="{StaticResource FlatButton}"
                            Click="BtnSkipBack_Click">
                        <Viewbox Width="14" Height="14" Stretch="Uniform">
                            <Path Data="{StaticResource IconSkipBack}" Fill="{StaticResource SecondaryTextBrush}"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="BtnFwd"
                            Width="28" Height="28" Padding="0"
                            Style="{StaticResource FlatButton}"
                            Margin="4,0,0,0"
                            Click="BtnFwd_Click">
                        <Viewbox Width="14" Height="14" Stretch="Uniform">
                            <Path Data="{StaticResource IconSkipForward}" Fill="{StaticResource SecondaryTextBrush}"/>
                        </Viewbox>
                    </Button>
                    <TextBlock x:Name="FwdSpeedLabel" Text="1×"
                               FontSize="11"                 Foreground="{StaticResource SecondaryTextBrush}"
                               VerticalAlignment="Center" Margin="4,0,8,0"
                               Width="26" TextAlignment="Center"/>
                    <Button x:Name="BtnSkipFwd" Content="30s"
                            Width="36" Height="28" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Margin="0,0,6,0"
                            Click="BtnSkipFwd_Click"/>
                    <Button x:Name="BtnLive"
                            Height="28" Padding="8,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="BtnLive_Click">
                        <StackPanel Orientation="Horizontal">
                             <Ellipse Width="6" Height="6" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="LIVE" Foreground="{StaticResource SecondaryTextBrush}" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnNow" Content="現在"
                            Height="28" Padding="6,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Margin="4,0,0,0"
                            Click="BtnNow_Click"/>
                    <Button x:Name="BtnExport"
                            Height="28" Padding="8,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Margin="4,0,0,0"
                            Click="BtnExport_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0">
                                <Path Data="{StaticResource IconExport}" Fill="{StaticResource SecondaryTextBrush}"/>
                            </Viewbox>
                            <TextBlock Text="匯出" Foreground="{StaticResource SecondaryTextBrush}" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnTalk"
                            Height="28" Padding="8,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Margin="4,0,0,0"
                            Click="BtnTalk_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0">
                                <Path Data="{StaticResource IconMicrophone}" Fill="{StaticResource SecondaryTextBrush}"/>
                            </Viewbox>
                            <TextBlock Text="對講" Foreground="{StaticResource SecondaryTextBrush}" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Border x:Name="TalkLevelBar" Width="4" Height="20"
                            Background="{StaticResource InputBackgroundBrush}" CornerRadius="2"
                            Margin="4,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Column="1" Margin="8,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                        <Button x:Name="FilterCont" Content="連續" Width="30" Height="18" FontSize="8"
                                Style="{StaticResource FlatButton}" Background="#332196F3"
                                Click="FilterCont_Click"/>
                        <Button x:Name="FilterMotion" Content="位移" Width="30" Height="18" FontSize="8"
                                Style="{StaticResource FlatButton}" Background="#33FF5722" Margin="1,0,0,0"
                                Click="FilterMotion_Click"/>
                        <Button x:Name="FilterAlarm" Content="警報" Width="30" Height="18" FontSize="8"
                                Style="{StaticResource FlatButton}" Background="#33F44336" Margin="1,0,0,0"
                                Click="FilterAlarm_Click"/>
                        <Button x:Name="FilterAi" Content="AI" Width="24" Height="18" FontSize="8"
                                Style="{StaticResource FlatButton}" Background="#33FFC107" Margin="1,0,0,0"
                                Click="FilterAi_Click"/>
                    </StackPanel>
                    <controls:NxTimeline x:Name="TimelineControl" Grid.Column="1"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Floating Bottom Control Bar -->
        <Border x:Name="ControlBar" Grid.Row="1" VerticalAlignment="Bottom"
                Background="{StaticResource SidebarBrush}" Padding="6,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button x:Name="BtnLayoutToggle" Width="auto" Height="22" Padding="6,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="LayoutToggle_Click"
                            ToolTip="版面配置">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0">
                                <Path Data="{StaticResource IconLayout}" Fill="{StaticResource SecondaryTextBrush}"/>
                            </Viewbox>
                            <TextBlock x:Name="LayoutLabel" Text="4" Foreground="{StaticResource SecondaryTextBrush}" FontSize="10"/>
                            <Viewbox Width="8" Height="8" Stretch="Uniform" Margin="4,0,0,0">
                                <Path Data="M0,0 L6,0 L3,4 Z" Fill="{StaticResource SecondaryTextBrush}"/>
                            </Viewbox>
                        </StackPanel>
                    </Button>
                    <Popup x:Name="LayoutPopup" PlacementTarget="{Binding ElementName=BtnLayoutToggle}"
                           Placement="Top" StaysOpen="False"
                           PopupAnimation="Fade" AllowsTransparency="True">
                        <Border Background="{StaticResource SidebarBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8">
                            <StackPanel>
                                <Grid x:Name="LayoutDragGrid" Width="160" Height="160"
                                      MouseMove="LayoutDragGrid_MouseMove"
                                      MouseLeave="LayoutDragGrid_MouseLeave"
                                      MouseDown="LayoutDragGrid_MouseDown"
                                      Background="Transparent"/>
                                <TextBlock x:Name="LayoutSizeLabel"
                                           Text="4"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="4,0"                             Foreground="{StaticResource DividerBrush}"/>
                    <Button x:Name="BtnSaveLayout"
                            Height="22" Padding="6,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            ToolTip="儲存目前版面配置"
                            Click="BtnSaveLayout_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0">
                                <Path Data="{StaticResource IconSave}" Fill="{StaticResource SecondaryTextBrush}"/>
                            </Viewbox>
                            <TextBlock Text="儲存" Foreground="{StaticResource SecondaryTextBrush}" FontSize="10"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel x:Name="PtzBar" Grid.Column="1"
                            Orientation="Horizontal" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <Button x:Name="BtnPtz"
                            Height="22" Padding="6,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="BtnPtz_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0">
                                <Path Data="{StaticResource IconPtz}" Fill="{StaticResource SecondaryTextBrush}"/>
                            </Viewbox>
                            <TextBlock Text="PTZ" Foreground="{StaticResource SecondaryTextBrush}" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="PtzLabel" Text="" FontSize="10" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Width="26" Height="22" Padding="0"
                        Style="{StaticResource FlatButton}"
                        ToolTip="全畫面"
                        Click="FullScreen_Click">
                    <Viewbox Width="12" Height="12" Stretch="Uniform">
                        <Path Data="{StaticResource IconFullScreen}" Fill="{StaticResource SecondaryTextBrush}"/>
                    </Viewbox>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>