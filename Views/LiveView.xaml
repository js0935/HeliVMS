<UserControl x:Class="HeliVMS.Views.LiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HeliVMS.Controls"
             Background="{StaticResource BackgroundBrush}"
             PreviewKeyDown="OnPreviewKeyDown">
    <UserControl.ContextMenu>
        <ContextMenu Background="{StaticResource SurfaceBrush}"
                     Foreground="{StaticResource TextBrush}"
                     BorderBrush="{StaticResource BorderBrush}">
            <MenuItem Header="全畫面" Foreground="{StaticResource TextBrush}"
                      Click="CtxFullscreen_Click"/>
        </ContextMenu>
    </UserControl.ContextMenu>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Main Content -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border x:Name="ToolbarPanel" Grid.Row="0" Padding="12,8"
                    Background="{StaticResource SurfaceBrush}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="即時監看" Style="{StaticResource PageHeader}"
                                   Margin="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CameraCountText"
                                   Text="0 台攝影機"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                        <TextBlock Text="分組" FontSize="11"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                        <ComboBox x:Name="GroupFilterCombo"
                                  Width="100" Height="24" FontSize="11"
                                  VerticalAlignment="Center"
                                  SelectionChanged="GroupFilterCombo_SelectionChanged"
                                  Background="{StaticResource InputBackgroundBrush}"
                                  Foreground="{StaticResource TextBrush}"
                                  BorderBrush="{StaticResource BorderBrush}"/>
                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                   Margin="6,0"/>
                        <!-- Layout buttons -->
                        <Button x:Name="Layout1" Content="1"
                                Width="24" Height="24" Padding="0" FontSize="10"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="1 分割 (1×1)"
                                Click="Layout_Click" Tag="1"/>
                        <Button x:Name="Layout4" Content="4"
                                Width="24" Height="24" Padding="0" FontSize="10"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="4 分割 (2×2)" Margin="1,0,0,0"
                                Click="Layout_Click" Tag="4"/>
                        <Button x:Name="Layout9" Content="9"
                                Width="24" Height="24" Padding="0" FontSize="10"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="9 分割 (3×3)" Margin="1,0,0,0"
                                Click="Layout_Click" Tag="9"/>
                        <Button x:Name="Layout16" Content="16"
                                Width="24" Height="24" Padding="0" FontSize="10"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="16 分割 (4×4)" Margin="1,0,0,0"
                                Click="Layout_Click" Tag="16"/>
                        <Button x:Name="Layout25" Content="25"
                                Width="24" Height="24" Padding="0" FontSize="10"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="25 分割 (5×5)" Margin="1,0,0,0"
                                Click="Layout_Click" Tag="25"/>
                        <Button x:Name="Layout36" Content="36"
                                Width="24" Height="24" Padding="0" FontSize="10"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="36 分割 (6×6)" Margin="1,0,0,0"
                                Click="Layout_Click" Tag="36"/>
                        <Button x:Name="Layout49" Content="49"
                                Width="24" Height="24" Padding="0" FontSize="10"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="49 分割 (7×7)" Margin="1,0,0,0"
                                Click="Layout_Click" Tag="49"/>
                        <Button x:Name="Layout64" Content="64"
                                Width="24" Height="24" Padding="0" FontSize="10"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="64 分割 (8×8)" Margin="1,0,0,0"
                                Click="Layout_Click" Tag="64"/>
                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                   Margin="6,0"/>
                        <Button x:Name="FullScreenBtn" Content="全畫面"
                                Height="24" Padding="6,0" FontSize="10"
                                Style="{StaticResource ModernButton}"
                                ToolTip="全畫面顯示攝影機"
                                Click="FullScreen_Click"/>
                    </StackPanel>

                    <!-- Live clock (top-right) -->
                    <Border Grid.Column="2"
                            Background="{StaticResource SecondarySurfaceBrush}"
                            CornerRadius="4" Padding="10,3"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="LiveClockDateText"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="LiveClockTimeText"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="13" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Video CameraGrid -->
            <controls:CameraGrid x:Name="CameraGridControl"
                                 Grid.Row="1" Margin="4"/>
        </Grid>

        <!-- PTZ Panel (sidebar) -->
        <Border Grid.Column="1" x:Name="PtzSidebar"
                Width="220"
                Background="{StaticResource SurfaceBrush}"
                BorderThickness="1,0,0,0"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="12,8"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="PtzCameraName" Text="PTZ 控制"
                           Style="{StaticResource SectionHeader}"
                           Margin="0,0,0,8"/>
                <controls:PTZControlPanel x:Name="PtzPanel"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
