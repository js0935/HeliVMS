<UserControl x:Class="HeliVMS.Views.LiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HeliVMS.Controls"
             Background="#1E1E1E"
             PreviewKeyDown="OnPreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <controls:LayoutTabBar x:Name="TabBar" Grid.Row="0"/>
        <controls:DynamicCameraGrid x:Name="VideoGrid" Grid.Row="1"/>

        <!-- Camera search filter -->
        <TextBox x:Name="CameraFilterBox" Grid.Row="1"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Width="200" Height="26" Margin="0,8,8,0"
                 FontSize="12" Padding="6,2"
                 Background="#CC111111" Foreground="{StaticResource TextBrush}"
                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                 Panel.ZIndex="30"
                 TextChanged="CameraFilterBox_TextChanged">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Background" Value="#CC111111"/>
                    <Style.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Background" Value="#CC111111"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>
        <TextBlock Text="🔍 搜尋攝影機" FontSize="10"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   Margin="0,13,216,0" Panel.ZIndex="31"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   IsHitTestVisible="False">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Text, ElementName=CameraFilterBox}" Value=""/>
                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=CameraFilterBox}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Timeline Container (floating overlay) -->
        <Border x:Name="TimelineContainer" Grid.Row="1"
                VerticalAlignment="Bottom"
                Height="64" Margin="10,0,10,36"
                Background="#CC111111"
                BorderThickness="0,1,0,0"
                BorderBrush="#33FFFFFF">
            <Grid Margin="4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <Button x:Name="BtnPlayPause" Content="⏯"
                            Width="30" Height="28" Padding="0" FontSize="16"
                            Style="{StaticResource FlatButton}"
                            Click="BtnPlayPause_Click"/>
                    <Button x:Name="BtnSkipBack" Content="⏪"
                            Width="28" Height="28" Padding="0" FontSize="12"
                            Style="{StaticResource FlatButton}"
                            Click="BtnSkipBack_Click"/>
                    <Button x:Name="BtnFwd" Content="⏩"
                            Width="28" Height="28" Padding="0" FontSize="14"
                            Style="{StaticResource FlatButton}"
                            Margin="4,0,0,0"
                            Click="BtnFwd_Click"/>
                    <TextBlock x:Name="FwdSpeedLabel" Text="1×"
                               FontSize="11" Foreground="#AAFFFFFF"
                               VerticalAlignment="Center" Margin="4,0,8,0"
                               Width="26" TextAlignment="Center"/>
                    <Button x:Name="BtnSkipFwd" Content="⏩ (30)"
                            Width="48" Height="28" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Margin="0,0,6,0"
                            Click="BtnSkipFwd_Click"/>
                    <Button x:Name="BtnLive" Content="🔴 LIVE"
                            Height="28" Padding="8,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="BtnLive_Click"/>
                    <Button x:Name="BtnNow" Content="現在"
                            Height="28" Padding="6,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Margin="4,0,0,0"
                            Click="BtnNow_Click"/>
                    <Button x:Name="BtnExport" Content="⬇ 匯出"
                            Height="28" Padding="8,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Margin="4,0,0,0"
                            Click="BtnExport_Click"/>
                    <Button x:Name="BtnTalk" Content="🎤 對講"
                            Height="28" Padding="8,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Margin="4,0,0,0"
                            Click="BtnTalk_Click"/>
                    <Border x:Name="TalkLevelBar" Width="4" Height="20"
                            Background="#444444" CornerRadius="2"
                            Margin="4,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Column="1" Margin="8,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                        <Button x:Name="FilterCont" Content="連續" Width="30" Height="18" FontSize="8"
                                Style="{StaticResource FlatButton}" Background="#332196F3"
                                Click="FilterCont_Click"/>
                        <Button x:Name="FilterMotion" Content="位移" Width="30" Height="18" FontSize="8"
                                Style="{StaticResource FlatButton}" Background="#33FF5722" Margin="1,0,0,0"
                                Click="FilterMotion_Click"/>
                        <Button x:Name="FilterAlarm" Content="警報" Width="30" Height="18" FontSize="8"
                                Style="{StaticResource FlatButton}" Background="#33F44336" Margin="1,0,0,0"
                                Click="FilterAlarm_Click"/>
                        <Button x:Name="FilterAi" Content="AI" Width="24" Height="18" FontSize="8"
                                Style="{StaticResource FlatButton}" Background="#33FFC107" Margin="1,0,0,0"
                                Click="FilterAi_Click"/>
                    </StackPanel>
                    <controls:NxTimeline x:Name="TimelineControl" Grid.Column="1"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Floating Bottom Control Bar -->
        <Border x:Name="ControlBar" Grid.Row="1" VerticalAlignment="Bottom"
                Background="#AA000000" Padding="6,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="1" Width="24" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="Layout_Click" Tag="1"/>
                    <Button Content="4" Width="24" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="Layout_Click" Tag="4" Margin="2,0,0,0"/>
                    <Button Content="9" Width="24" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="Layout_Click" Tag="9" Margin="2,0,0,0"/>
                    <Button Content="16" Width="24" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="Layout_Click" Tag="16" Margin="2,0,0,0"/>
                    <Button Content="64" Width="24" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="Layout_Click" Tag="64" Margin="2,0,0,0"/>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="4,0" Foreground="#40FFFFFF"/>
                    <Button x:Name="BtnSaveLayout" Content="💾 儲存" Width="48" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            ToolTip="儲存目前版面配置"
                            Click="BtnSaveLayout_Click"/>
                </StackPanel>

                <StackPanel x:Name="PtzBar" Grid.Column="1"
                            Orientation="Horizontal" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <Button x:Name="BtnPtz" Content="🎥 PTZ" Width="50" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="BtnPtz_Click"/>
                    <TextBlock x:Name="PtzLabel" Text="" FontSize="10" Foreground="#CCFFFFFF"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" Content="⛶" Width="26" Height="22" Padding="0" FontSize="13"
                        Style="{StaticResource FlatButton}"
                        Click="FullScreen_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>