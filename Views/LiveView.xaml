<UserControl x:Class="HeliVMS.Views.LiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HeliVMS.Controls"
             Background="#1E1E1E"
             PreviewKeyDown="OnPreviewKeyDown">
    <Grid>
        <controls:DynamicCameraGrid x:Name="VideoGrid"/>

        <!-- Timeline Container (floating overlay) -->
        <Border x:Name="TimelineContainer"
                VerticalAlignment="Bottom"
                Height="45" Margin="10,0,10,36"
                Background="#CC111111"
                BorderThickness="0,1,0,0"
                BorderBrush="#33FFFFFF">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnPlayPause" Content="⏯"
                            Width="30" Height="28" Padding="0" FontSize="16"
                            Style="{StaticResource FlatButton}"
                            Click="BtnPlayPause_Click"/>
                    <Button x:Name="BtnFwd" Content="⏩"
                            Width="28" Height="28" Padding="0" FontSize="14"
                            Style="{StaticResource FlatButton}"
                            Margin="4,0,0,0"
                            Click="BtnFwd_Click"/>
                    <TextBlock x:Name="FwdSpeedLabel" Text="1×"
                               FontSize="11" Foreground="#AAFFFFFF"
                               VerticalAlignment="Center" Margin="4,0,8,0"
                               Width="26" TextAlignment="Center"/>
                    <Button x:Name="BtnLive" Content="🔴 LIVE"
                            Height="28" Padding="8,0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="BtnLive_Click"/>
                </StackPanel>

                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Canvas x:Name="RecordingBars"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            IsHitTestVisible="False" Height="6"/>
                    <Slider x:Name="GlobalTimeline"
                            Minimum="0" Maximum="86400" Value="86400"
                            SmallChange="60" LargeChange="900"
                            ValueChanged="GlobalTimeline_ValueChanged"
                            PreviewMouseDown="GlobalTimeline_PreviewMouseDown"
                            Height="22" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TimelineTimeLabel"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Margin="0,-2,0,0"
                               FontSize="9" Foreground="#99FFFFFF"
                               IsHitTestVisible="False"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Floating Bottom Control Bar -->
        <Border x:Name="ControlBar" VerticalAlignment="Bottom"
                Background="#AA000000" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="4,0" Foreground="#40FFFFFF"/>
                    <Button Content="1" Width="26" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="Layout_Click" Tag="1"/>
                    <Button Content="4" Width="26" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="Layout_Click" Tag="4" Margin="2,0,0,0"/>
                    <Button Content="9" Width="26" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="Layout_Click" Tag="9" Margin="2,0,0,0"/>
                    <Button Content="16" Width="26" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="Layout_Click" Tag="16" Margin="2,0,0,0"/>
                    <Button Content="64" Width="26" Height="22" Padding="0" FontSize="10"
                            Style="{StaticResource FlatButton}"
                            Click="Layout_Click" Tag="64" Margin="2,0,0,0"/>
                </StackPanel>

                <StackPanel x:Name="PtzBar" Grid.Column="1"
                            Orientation="Horizontal" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <Button Content="◄" Width="24" Height="22" Padding="0" FontSize="11"
                            Style="{StaticResource FlatButton}"
                            Click="PtzLeft_Click"/>
                    <Button Content="▲" Width="24" Height="22" Padding="0" FontSize="11"
                            Style="{StaticResource FlatButton}"
                            Click="PtzUp_Click" Margin="2,0,0,0"/>
                    <Button Content="▼" Width="24" Height="22" Padding="0" FontSize="11"
                            Style="{StaticResource FlatButton}"
                            Click="PtzDown_Click" Margin="2,0,0,0"/>
                    <Button Content="►" Width="24" Height="22" Padding="0" FontSize="11"
                            Style="{StaticResource FlatButton}"
                            Click="PtzRight_Click" Margin="2,0,0,0"/>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="4,0" Foreground="#40FFFFFF"/>
                    <Button Content="＋" Width="24" Height="22" Padding="0" FontSize="12"
                            Style="{StaticResource FlatButton}"
                            Click="PtzZoomIn_Click" Margin="2,0,0,0"/>
                    <Button Content="－" Width="24" Height="22" Padding="0" FontSize="12"
                            Style="{StaticResource FlatButton}"
                            Click="PtzZoomOut_Click" Margin="2,0,0,0"/>
                    <TextBlock x:Name="PtzLabel" Text="" FontSize="10" Foreground="#CCFFFFFF"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" Content="⛶" Width="26" Height="22" Padding="0" FontSize="13"
                        Style="{StaticResource FlatButton}"
                        Click="FullScreen_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>