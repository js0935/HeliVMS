<UserControl x:Class="HeliVMS.Views.DeviceManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:HeliVMS.Converters"
             xmlns:controls="clr-namespace:HeliVMS.Controls"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <conv:NullToEmptyConverter x:Key="NullToEmptyConverter"/>
        <conv:RecordingConfigToStatusConverter x:Key="RecordingConfigToStatusConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Nx-style tab bar -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel Orientation="Horizontal" Margin="16,0">
                <Button x:Name="TabDevice" Tag="0" Padding="16,12" FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" Background="Transparent"
                        Foreground="{DynamicResource TextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="{DynamicResource PrimaryBrush}"
                        Click="TabButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconCamera}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="攝影機管理"/>
                    </StackPanel>
                </Button>
                <Button x:Name="TabRecording" Tag="1" Padding="16,12" FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" Background="Transparent"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconRecording}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="錄影排程"/>
                    </StackPanel>
                </Button>
                <Button x:Name="TabStorage" Tag="2" Padding="16,12" FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" Background="Transparent"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconSave}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="儲存管理"/>
                    </StackPanel>
                </Button>
                <Button x:Name="TabChannel" Tag="3" Padding="16,12" FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" Background="Transparent"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconLayout}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="頻道管理"/>
                    </StackPanel>
                </Button>
                <Button x:Name="TabGroup" Tag="4" Padding="16,12" FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" Background="Transparent"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconFolder}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="攝影機群組"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1">
            <!-- ═══ Tab 0: Camera Management (Nx-style sidebar + detail) ═══ -->
            <Grid x:Name="DeviceSettingsPanel" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left sidebar: camera list -->
                <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                        BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderBrush}">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="16,16,16,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="攝影機" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <Border Grid.Column="1" Background="{DynamicResource PrimaryBrush}"
                                    CornerRadius="10" Padding="8,2" MinWidth="20">
                                <TextBlock x:Name="CameraCountBadge" Text="0/0" FontSize="11"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Search box -->
                        <Border Grid.Row="1" Margin="12,0,12,8"
                                Background="{DynamicResource InputBackgroundBrush}" CornerRadius="4"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                            <Grid>
                                <TextBox x:Name="SearchBox"
                                         Margin="28,6,8,6" Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource TextBrush}"
                                         FontSize="12"
                                         ToolTip="輸入名稱或 IP 進行搜尋"
                                         TextChanged="SearchBox_TextChanged"/>
                                <Path Data="{StaticResource IconSearch}"
                                      Fill="{DynamicResource SecondaryTextBrush}"
                                      Width="14" Height="14" Stretch="Uniform"
                                      HorizontalAlignment="Left" Margin="8,0,0,0"
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Camera ListBox -->
                        <ListBox Grid.Row="2" x:Name="CameraListBox"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="CameraListBox_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource SecondarySurfaceBrush}"/>
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource PrimaryBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource DividerBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Status dot -->
                                        <Ellipse Grid.Column="0" Width="10" Height="10"
                                                 Fill="{Binding StatusColor}"
                                                 Margin="0,0,10,0" VerticalAlignment="Center"/>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding IpAddress}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Bottom toolbar -->
                        <Border Grid.Row="3" BorderThickness="0,1,0,0"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Padding="8,8,8,4">
                            <WrapPanel>
                                <Button x:Name="AddCameraButton" Content="＋ 新增"
                                        Style="{StaticResource ModernButton}" FontSize="11"
                                        Height="28" Padding="8,0"
                                        Click="AddCameraButton_Click"/>
                                <Button x:Name="OnvifScanButton" Content="掃描"
                                        Style="{StaticResource SecondaryButton}" FontSize="11"
                                        Height="28" Padding="8,0" Margin="4,0,0,0"
                                        Click="OnvifScanButton_Click"/>
                                <Button x:Name="EditCameraButton" Content="編輯"
                                        Style="{StaticResource SecondaryButton}" FontSize="11"
                                        Height="28" Padding="8,0" Margin="4,0,0,0"
                                        IsEnabled="False"
                                        Click="EditCameraButton_Click"/>
                                <Button x:Name="DeleteCameraButton" Content="刪除"
                                        Style="{StaticResource SecondaryButton}" FontSize="11"
                                        Height="28" Padding="8,0" Margin="4,0,0,0"
                                        IsEnabled="False"
                                        Click="DeleteCameraButton_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- Import/Export -->
                        <Border Grid.Row="4" BorderThickness="0,1,0,0"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Padding="8,4,8,8">
                            <WrapPanel>
                                <Button Content="匯入"
                                        Style="{StaticResource SecondaryButton}" FontSize="11"
                                        Height="24" Padding="6,0"
                                        Click="ImportCsv_Click"/>
                                <Button Content="匯出"
                                        Style="{StaticResource SecondaryButton}" FontSize="11"
                                        Height="24" Padding="6,0" Margin="4,0,0,0"
                                        Click="ExportCsv_Click"/>
                                <Button Content="舊版匯入"
                                        Style="{StaticResource SecondaryButton}" FontSize="11"
                                        Height="24" Padding="6,0" Margin="4,0,0,0"
                                        Click="ImportLegacyButton_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- Scan progress panel -->
                        <Border Grid.Row="2" x:Name="ScanProgressPanel" Visibility="Collapsed"
                                Background="{DynamicResource SurfaceBrush}" VerticalAlignment="Top"
                                Margin="0,80,0,0" Padding="12" CornerRadius="6">
                            <StackPanel>
                                <TextBlock x:Name="ScanProgressText" Text="掃描中..."
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <ProgressBar x:Name="ScanProgressBar" Height="4"
                                             Minimum="0" Maximum="254"
                                             Foreground="{DynamicResource PrimaryBrush}"
                                             Background="{DynamicResource InputBackgroundBrush}"
                                             BorderThickness="0" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Right side: detail/content -->
                <Grid Grid.Column="1" Margin="24,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Sub-tab bar: Detail / Recording / Channels -->
                    <Border Grid.Row="0" Background="Transparent"
                            BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"
                            Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="SubTabDetail" Tag="detail"
                                    Padding="12,6" FontSize="12" FontWeight="SemiBold"
                                    Cursor="Hand" Background="Transparent"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderThickness="0,0,0,2" BorderBrush="{DynamicResource PrimaryBrush}"
                                    Click="SubTabButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconInfo}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"/>
                                    <TextBlock Text="詳細資訊"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="SubTabRecording" Tag="recording"
                                    Padding="12,6" FontSize="12" FontWeight="SemiBold"
                                    Cursor="Hand" Background="Transparent"
                                    Foreground="{DynamicResource SecondaryTextBrush}"
                                    BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                    Click="SubTabButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconRecording}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"/>
                                    <TextBlock Text="錄影設定"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="SubTabChannels" Tag="channels"
                                    Padding="12,6" FontSize="12" FontWeight="SemiBold"
                                    Cursor="Hand" Background="Transparent"
                                    Foreground="{DynamicResource SecondaryTextBrush}"
                                    BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                    Click="SubTabButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLayout}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"/>
                                    <TextBlock Text="頻道管理"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Empty state (no camera selected) -->
                    <Border Grid.Row="1" x:Name="EmptyStatePanel"
                            Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                            VerticalAlignment="Stretch">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconCamera}"
                                  Fill="{DynamicResource SecondaryTextBrush}"
                                  Width="48" Height="48" Stretch="Uniform"
                                  Opacity="0.3" Margin="0,0,0,12"/>
                            <TextBlock Text="請從左側選取一台攝影機"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="14"/>
                            <TextBlock Text="或點擊「＋ 新增」來加入新設備"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Camera Detail panel -->
                    <ScrollViewer Grid.Row="1" x:Name="DetailScrollViewer" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Camera identity header -->
                            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="8" Padding="20" Margin="0,0,0,16"
                                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" x:Name="DetailStatusDot"
                                             Width="16" Height="16" Fill="{DynamicResource SuccessBrush}"
                                             Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="DetailName" FontSize="20" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock x:Name="DetailIp" FontSize="13"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Margin="0,4,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock x:Name="DetailStatusText" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SuccessBrush}" Margin="0,0,12,0"/>
                                            <TextBlock x:Name="DetailChannelNumberText" FontSize="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}">
                                                <Run Text="頻道 "/><Run x:Name="DetailChannelNumber" Text="-"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="測試連線"
                                                Style="{StaticResource SecondaryButton}" FontSize="11"
                                                Height="28" Padding="10,0"
                                                Click="TestConnection_Click"/>
                                        <Button Content="複製 RTSP"
                                                Style="{StaticResource SecondaryButton}" FontSize="11"
                                                Height="28" Padding="10,0" Margin="6,0,0,0"
                                                Click="CopyRtspUrl_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Camera details grid -->
                            <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="8" Padding="20" Margin="0,0,0,16"
                                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="設備資訊" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16"/>
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,12">
                                            <TextBlock Text="品牌 / 型號" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                            <TextBlock x:Name="DetailManufacturer" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,16,12">
                                            <TextBlock Text="序號" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                            <TextBlock x:Name="DetailSerial" Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                                            <TextBlock Text="ONVIF 連接埠" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                            <TextBlock x:Name="DetailOnvifPort" Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,12">
                                            <TextBlock Text="啟用狀態" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                            <TextBlock x:Name="DetailEnabledText" Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,16,12">
                                            <TextBlock Text="PTZ 支援" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                            <TextBlock x:Name="DetailPtzText" Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="2">
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,12">
                                            <TextBlock Text="串流1 (Main)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                            <TextBlock x:Name="DetailRtspUrl" Foreground="{DynamicResource TextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                                            <TextBlock Text="串流2 (Sub)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                            <TextBlock x:Name="DetailRtspUrlSub" Foreground="{DynamicResource TextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>

                    <!-- Recording settings sub-panel -->
                    <controls:RecordingSettingsPage Grid.Row="1" x:Name="SubRecordingPanel" Visibility="Collapsed"/>

                    <!-- Channel management sub-panel -->
                    <controls:ChannelManagementPage Grid.Row="1" x:Name="SubChannelPanel" Visibility="Collapsed"/>
                </Grid>
            </Grid>

            <!-- ═══ Tab 1: Recording Settings ═══ -->
            <controls:RecordingSettingsPage Grid.Row="1" x:Name="RecordingSettingsPanel" Visibility="Collapsed" Margin="24"/>

            <!-- ═══ Tab 2: Storage Management ═══ -->
            <controls:StorageManagerPage Grid.Row="1" x:Name="StorageManagerPanel" Visibility="Collapsed" Margin="24"/>

            <!-- ═══ Tab 3: Channel Management ═══ -->
            <controls:ChannelManagementPage Grid.Row="1" x:Name="ChannelManagementPanel" Visibility="Collapsed" Margin="24"/>

            <!-- ═══ Tab 4: Camera Groups ═══ -->
            <Grid Grid.Row="1" x:Name="GroupPanel" Visibility="Collapsed" Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                    <StackPanel>
                        <TextBlock Text="群組列表" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                        <ListBox x:Name="GroupListBox" Background="Transparent" BorderThickness="0"
                                 MinHeight="200" SelectionChanged="GroupList_SelectionChanged"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NewGroupNameBox" MinWidth="100" Height="28" FontSize="12"
                                     Style="{StaticResource ModernTextBox}"/>
                            <Button Grid.Column="1" Content="新增" Height="28" FontSize="11" Padding="8,0" Margin="6,0,0,0"
                                    Style="{StaticResource ModernButton}" Click="AddGroup_Click"/>
                        </Grid>
                        <Button x:Name="DeleteGroupBtn" Content="刪除選取群組" Height="28" FontSize="11"
                                Margin="0,8,0,0" Style="{StaticResource SecondaryButton}"
                                Click="DeleteGroup_Click"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="16,0,0,0"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                    <StackPanel>
                        <TextBlock x:Name="GroupCameraHeader" Text="選取群組以編輯攝影機"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="GroupCameraCheckList" Background="Transparent" BorderThickness="0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsInGroup}"
                                              FontSize="13" Foreground="{DynamicResource TextBrush}"
                                              Margin="0,3" Padding="4,2"
                                              Checked="GroupCameraCheck_Changed"
                                              Unchecked="GroupCameraCheck_Changed"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
