<!-- ============================================================
     HeliVMS - 智慧影像管理系統     禾秝軟體開發團隊 / 代碼設計：洪俊士 / 版本：V1.0.0
     ============================================================ -->
<UserControl x:Class="HeliVMS.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:HeliVMS.Views"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="系統設定" Style="{StaticResource PageHeader}"/>

        <!-- Tab bar -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource BorderBrush}" Margin="0,12,0,16">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="TabEventLog" Content="系統日誌" Tag="0" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource TextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="{StaticResource PrimaryBrush}"
                        Click="TabButton_Click"/>
                <Button x:Name="TabFfmpeg" Content="FFmpeg" Tag="1" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click"/>
                <Button x:Name="TabFont" Content="字型設定" Tag="2" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click"/>
                <Button x:Name="TabRetention" Content="錄影保留" Tag="3" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click"/>
                <Button x:Name="TabUser" Content="用戶管理" Tag="4" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click"/>
                <Button x:Name="TabDebug" Content="除錯" Tag="5" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click"/>
                <Button x:Name="TabMediaMTX" Content="MediaMTX" Tag="6" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click"/>
                <Button x:Name="TabEventRules" Content="事件規則" Tag="7" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click"/>
                <Button x:Name="TabNotification" Content="通知設定" Tag="8" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click"/>
                <Button x:Name="TabSchedule" Content="錄影排程" Tag="10" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click"/>
                <Button x:Name="TabAuditLog" Content="稽核日誌" Tag="9" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click"/>
                <Button x:Name="TabBackup" Content="備份還原" Tag="11" Padding="16,10" FontSize="13"
                        FontWeight="SemiBold" Cursor="Hand" Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Click="TabButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Event log panel -->
        <ScrollViewer Grid.Row="2" x:Name="EventLogPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="系統事件日誌"
                                       Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                            <Button Grid.Column="1" Content="重新整理"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="28" FontSize="11" Margin="0,0,8,0"
                                    Click="RefreshLog_Click"/>
                            <Button Grid.Column="2" Content="清除日誌"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="28" FontSize="11"
                                    Click="ClearLog_Click"/>
                        </Grid>

                        <!-- Filter row -->
                        <WrapPanel Margin="0,4,0,8">
                            <TextBlock Text="分類" VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <ComboBox x:Name="CategoryFilter" Width="100" Margin="4,0,12,0"
                                      Style="{StaticResource ModernComboBox}"
                                      SelectionChanged="Filter_Changed">
                                <ComboBoxItem Content="全部" Tag=""/>
                            </ComboBox>
                            <TextBlock Text="層級" VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <ComboBox x:Name="SeverityFilter" Width="80" Margin="4,0,12,0"
                                      Style="{StaticResource ModernComboBox}"
                                      SelectionChanged="Filter_Changed">
                                <ComboBoxItem Content="全部" Tag="" IsSelected="True"/>
                                <ComboBoxItem Content="INFO" Tag="INFO"/>
                                <ComboBoxItem Content="WARN" Tag="WARN"/>
                                <ComboBoxItem Content="ERROR" Tag="ERROR"/>
                            </ComboBox>
                            <TextBlock Text="搜尋" VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <TextBox x:Name="SearchBox" Width="180" Margin="4,0,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     TextChanged="SearchBox_TextChanged"/>
                        </WrapPanel>

                        <DataGrid x:Name="EventLogGrid"
                                  Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False"
                                  CanUserResizeRows="False"
                                  MaxHeight="480"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeColumns="True"
                                  ColumnHeaderStyle="{StaticResource ModernColumnHeader}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="時間" Binding="{Binding Timestamp, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" Width="130"/>
                                <DataGridTextColumn Header="層級" Binding="{Binding Severity}" Width="55"/>
                                <DataGridTextColumn Header="分類" Binding="{Binding Category}" Width="70"/>
                                <DataGridTextColumn Header="來源" Binding="{Binding Source}" Width="100"/>
                                <DataGridTextColumn Header="訊息" Binding="{Binding Message}" Width="*" MinWidth="200"/>
                                <DataGridTextColumn Header="詳細資訊" Binding="{Binding Detail}" Width="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Font settings panel -->
        <ScrollViewer Grid.Row="2" x:Name="FontPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="即時監看名稱字型大小" Style="{StaticResource SectionHeader}" Margin="0,0,0,16"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="字體大小"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Row="0" Grid.Column="1"
                                    x:Name="FontSizeSlider"
                                    Minimum="8" Maximum="32" TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Margin="12,0" VerticalAlignment="Center"
                                    ValueChanged="FontSizeSlider_ValueChanged"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       x:Name="FontSizeValue"
                                       Text="11" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" MinWidth="24"
                                       TextAlignment="Center"/>
                        </Grid>

                        <!-- Preview -->
                        <TextBlock Text="預覽" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <Border Background="#80000000" CornerRadius="3"
                                Padding="12,6" HorizontalAlignment="Left">
                            <TextBlock x:Name="FontPreviewText"
                                       Text="CH1 攝影機名稱"
                                       Foreground="White"/>
                        </Border>

                        <Button Content="套用字型設定"
                                Style="{StaticResource ModernButton}"
                                Height="32" FontSize="12" Padding="16,0"
                                Margin="0,16,0,0" HorizontalAlignment="Left"
                                Click="SaveFontSettings_Click"/>
                    </StackPanel>
                </Border>

                <!-- Recording overlay settings -->
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="錄影崁入設定" Style="{StaticResource SectionHeader}" Margin="0,0,0,16"/>
                        <CheckBox x:Name="EnableCameraNameOverlayCheckBox"
                                  Content="攝影機名稱崁入"
                                  FontSize="13"
                                  Foreground="{StaticResource TextBrush}"
                                  Margin="0,0,0,8"
                                  IsChecked="True"/>
                        <CheckBox x:Name="EnableTimestampOverlayCheckBox"
                                  Content="時間戳崁入"
                                  FontSize="13"
                                  Foreground="{StaticResource TextBrush}"
                                  IsChecked="True"/>
                        <TextBlock Text="啟用後，錄影時會將攝影機名稱與時間戳直接疊加在影片畫面上（燒錄進影片，所有播放器均可顯示）。"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0"/>
                        <TextBlock Text="啟用後將增加10倍CPU處理器10倍RAM記憶體負載。"
                                   Foreground="#FFCC4400"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                        <Button Content="套用並重新啟動"
                                x:Name="ApplyOverlayBtn"
                                Style="{StaticResource ModernButton}"
                                Height="32" FontSize="12" Padding="16,0"
                                Margin="0,12,0,0" HorizontalAlignment="Left"
                                Click="ApplyOverlayAndRestart_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Retention panel -->
        <ScrollViewer Grid.Row="2" x:Name="RetentionPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="錄影保留政策" Style="{StaticResource SectionHeader}" Margin="0,0,0,16"/>

                        <CheckBox x:Name="EnableAutoPurgeCheckBox"
                                  Content="啟用自動清理"
                                  FontSize="13"
                                  Foreground="{StaticResource TextBrush}"
                                  Margin="0,0,0,16"
                                  IsChecked="True"
                                  Checked="RetentionSettingChanged"
                                  Unchecked="RetentionSettingChanged"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="保留天數"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <Slider Grid.Row="0" Grid.Column="1"
                                    x:Name="RetentionDaysSlider"
                                    Minimum="1" Maximum="365" TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Margin="8,0" VerticalAlignment="Center"
                                    ValueChanged="RetentionSlider_ValueChanged"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       x:Name="RetentionDaysValue"
                                       Text="90" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" MinWidth="36"
                                       TextAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                       Text="超過此天數的錄影檔案將在啟動時或手動清除時刪除。"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="硬上限 (GB)"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     x:Name="MaxStorageGBTextBox"
                                     Text="0" FontSize="13"
                                     Style="{StaticResource ModernTextBox}"
                                     TextChanged="RetentionSettingChanged"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="0 = 不限制。超過時從最舊的錄影開始自動刪除。"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="11" VerticalAlignment="Center"
                                       TextWrapping="Wrap" Margin="8,0,0,0"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                       x:Name="CurrentStorageText"
                                       Text="" FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Margin="0,4,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="手動清除" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock Text="立即依照上述設定執行清理（刪除過期錄影檔案與 DB 記錄）。"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PurgeNowBtn" Content="立即清除"
                                    Style="{StaticResource ModernButton}"
                                    Height="32" FontSize="12" Padding="20,0"
                                    Click="PurgeNow_Click"/>
                            <TextBlock Grid.Column="1" x:Name="PurgeResultText"
                                       Text="" FontSize="11"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- User management panel -->
        <ScrollViewer Grid.Row="2" x:Name="UserPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <views:UserManagementView Margin="0"/>
        </ScrollViewer>

        <!-- Debug panel -->
        <ScrollViewer Grid.Row="2" x:Name="DebugPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel>
                <!-- Debug display settings -->
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="除錯顯示" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                        <CheckBox x:Name="ShowDragDebugCheckBox"
                                  Content="顯示拖曳除錯面板（畫面左上角）"
                                  FontSize="13"
                                  Foreground="{StaticResource TextBrush}"
                                  IsChecked="False"
                                  Checked="ShowDragDebugCheckBox_Changed"
                                  Unchecked="ShowDragDebugCheckBox_Changed"/>
                        <TextBlock Text="啟用後在即時監看畫面左上角顯示拖曳操作的除錯資訊疊層。"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Async RTSP settings -->
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="非同步 RTSP 客戶端" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                        <CheckBox x:Name="UseAsyncRtspRecordingCheckBox"
                                  Content="錄影使用非同步 RTSP（取代 FFmpeg 內建 demuxer）"
                                  FontSize="13"
                                  Foreground="{StaticResource TextBrush}"
                                  IsChecked="False"
                                  Checked="UseAsyncRtspRecording_Changed"
                                  Unchecked="UseAsyncRtspRecording_Changed"/>
                        <TextBlock Text="啟用後錄影引擎使用自訂 async TCP 客戶端進行 RTSP 握手與 RTP 解封包，取代 FFmpeg 內建 RTSP 解複用器。可消除每路攝影機一條阻塞執行緒。需重啟錄影生效。"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                        <CheckBox x:Name="UseAsyncRtspLiveViewCheckBox"
                                  Content="即時監看使用非同步 RTSP"
                                  FontSize="13"
                                  Foreground="{StaticResource TextBrush}"
                                  IsChecked="False"
                                  Margin="0,12,0,0"
                                  Checked="UseAsyncRtspLiveView_Changed"
                                  Unchecked="UseAsyncRtspLiveView_Changed"/>
                        <TextBlock Text="啟用後即時監看畫面使用非同步 RTSP 客戶端連線攝影機。需重新連線生效。"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- System info -->
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="系統資訊" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="應用程式版本"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SysVersionText"
                                       Text="V1.0.0" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="作業系統"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SysOsText"
                                       Text="—" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text=".NET 版本"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SysDotnetText"
                                       Text="—" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="攝影機總數"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SysCameraCountText"
                                       Text="—" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="8,0,0,4"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="設定檔路徑"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="SysSettingsPathText"
                                       Text="—" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="8,0,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ONVIF camera model support -->
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="ONVIF 攝影機型號支援" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="目前已支援"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="BrandCountText"
                                       Text="— 個品牌 ／ — 個型號" Foreground="{StaticResource TextBrush}" FontSize="12"
                                       Margin="4,0,0,0"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,0">
                            <Button x:Name="UpdateBrandConfigBtn"
                                    Content="更新 ONVIF 品牌資料"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="28" FontSize="11" Padding="12,0"
                                    Click="UpdateBrandConfig_Click"/>
                            <TextBlock x:Name="BrandUpdateStatusText"
                                       Text=""
                                       FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Performance tuning -->
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="效能調校" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="子串流切換閾值"
                                       Foreground="{StaticResource TextBrush}" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="SubStreamThresholdSlider"
                                    Grid.Column="1" Minimum="2" Maximum="16" TickFrequency="1"
                                    IsSnapToTickEnabled="True" Value="4"
                                    Margin="8,0"
                                    ValueChanged="SubStreamThresholdSlider_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="SubStreamThresholdText"
                                       Text="4" Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="當即時監看網格顯示超過此數量的攝影機時，自動切換為子串流以節省頻寬。"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <CheckBox x:Name="EnableHwAccelCheckBox"
                                  Content="啟用硬體加速轉碼（Intel QSV / NVIDIA NVENC）"
                                  FontSize="13"
                                  Foreground="{StaticResource TextBrush}"
                                  IsChecked="True"
                                  Checked="EnableHwAccel_Changed"
                                  Unchecked="EnableHwAccel_Changed"/>
                        <TextBlock Text="啟用後 MediaMTX 與 FFmpeg 將嘗試使用 GPU 進行硬體加速編解碼，降低 CPU 使用率。"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Dev tools -->
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="開發工具" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                        <WrapPanel>
                            <Button Content="開啟設定檔資料夾"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="28" FontSize="11" Padding="12,0"
                                    Click="OpenSettingsFolder_Click"/>
                            <Button Content="開啟攝影機資料檔"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="28" FontSize="11" Padding="12,0" Margin="8,0,0,0"
                                    Click="OpenCameraDataFile_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- System operations -->
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="系統操作" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock Text="重新啟動或關閉 HeliVMS 應用程式。"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <WrapPanel>
                            <Button Content="重新啟動應用程式"
                                    Style="{StaticResource ModernButton}"
                                    Height="32" FontSize="12" Padding="16,0"
                                    Click="RestartApp_Click"/>
                            <Button Content="關閉應用程式"
                                    Style="{StaticResource ModernButton}"
                                    Height="32" FontSize="12" Padding="16,0" Margin="8,0,0,0"
                                    Click="ShutdownApp_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- MediaMTX panel -->
        <ScrollViewer Grid.Row="2" x:Name="MediaMTXPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="MediaMTX 媒體路由器" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="狀態"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,4">
                                <Ellipse x:Name="MtxStatusDot" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="MtxStatusText" Text="檢查中..." Foreground="{StaticResource TextBrush}" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="運作時間"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="MtxUptimeText" Text="—"
                                       Foreground="{StaticResource TextBrush}" FontSize="12" Margin="8,0,0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="RTSP 埠號"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="MtxPortText" Text="8554"
                                       Foreground="{StaticResource TextBrush}" FontSize="12" Margin="8,0,0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="組態路徑"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="MtxConfigPathText" Text="—"
                                       Foreground="{StaticResource TextBrush}" FontSize="12" Margin="8,0,0,0" TextWrapping="Wrap"/>
                        </Grid>
                        <WrapPanel>
                            <Button x:Name="MtxRestartBtn" Content="重新啟動"
                                    Style="{StaticResource ModernButton}"
                                    Height="28" FontSize="11" Padding="16,0"
                                    Click="MtxRestart_Click"/>
                            <Button x:Name="MtxRefreshBtn" Content="重新整理"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="28" FontSize="11" Padding="12,0" Margin="8,0,0,0"
                                    Click="MtxRefresh_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="轉碼設定" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                        <CheckBox x:Name="MtxHwAccelCheckBox"
                                  Content="啟用硬體加速轉碼（Intel QSV / NVIDIA NVENC）"
                                  FontSize="13"
                                  Foreground="{StaticResource TextBrush}"
                                  IsChecked="True"
                                  Checked="MtxHwAccel_Changed"
                                  Unchecked="MtxHwAccel_Changed"/>
                        <TextBlock Text="啟用後 MediaMTX 與 FFmpeg 將嘗試使用 GPU 進行硬體加速編解碼，降低 CPU 使用率。需重新啟動 MediaMTX 生效。"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Event rules panel -->
        <ScrollViewer Grid.Row="2" x:Name="EventRulesPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="事件規則引擎"
                                       Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                            <WrapPanel Grid.Column="1">
                                <Button x:Name="CopyRuleBtn" Content="📋 複製"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="28" FontSize="11" Padding="8,0"
                                        Click="CopyRule_Click"/>
                                <Button x:Name="EnableAllRulesBtn" Content="✓ 全部啟用"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="28" FontSize="11" Padding="8,0" Margin="4,0,0,0"
                                        Click="EnableAllRules_Click"/>
                                <Button x:Name="DisableAllRulesBtn" Content="✗ 全部停用"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="28" FontSize="11" Padding="8,0" Margin="4,0,0,0"
                                        Click="DisableAllRules_Click"/>
                                <Button x:Name="AddRuleBtn" Content="+ 新增規則"
                                        Style="{StaticResource ModernButton}"
                                        Height="28" FontSize="11" Padding="12,0" Margin="4,0,0,0"
                                        Click="AddRule_Click"/>
                            </WrapPanel>
                        </Grid>
                        <DataGrid x:Name="EventRulesGrid"
                                  Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False"
                                  CanUserResizeRows="False"
                                  MaxHeight="480"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  MouseDoubleClick="EventRulesGrid_MouseDoubleClick"
                                  KeyDown="EventRulesGrid_KeyDown">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="規則名稱" Binding="{Binding Name}" Width="*" MinWidth="140"/>
                                <DataGridCheckBoxColumn Header="啟用" Binding="{Binding Enabled}" Width="50"/>
                                <DataGridTextColumn Header="條件數" Binding="{Binding Conditions.Count}" Width="60"/>
                                <DataGridTextColumn Header="動作數" Binding="{Binding Actions.Count}" Width="60"/>
                                <DataGridTextColumn Header="建立時間" Binding="{Binding CreatedAt, StringFormat=\{0:MM/dd HH:mm\}}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="事件規則運作方式" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12">
                            當條件成立時，系統會自動執行對應動作。目前支援的事件類型：
                        </TextBlock>
                        <TextBlock Text="• CameraDisconnected — 攝影機離線&#x0a;• CameraReconnected — 攝影機恢復連線&#x0a;• MotionDetected — 移動偵測&#x0a;• RecordingFailed — 錄影失敗"
                                   Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Notification settings panel -->
        <ScrollViewer Grid.Row="2" x:Name="NotificationPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="電子郵件通知 (SMTP)" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="啟用郵件通知" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <CheckBox x:Name="EmailEnabledCheck" Grid.Row="0" Grid.Column="1" Margin="8,0,0,4" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="SMTP 主機" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox x:Name="SmtpHostBox" Grid.Row="1" Grid.Column="1" FontSize="12" Padding="4,3" Margin="8,0,0,4"
                                     Background="#2D2D2D" Foreground="#E1E1E1" BorderBrush="#444444" BorderThickness="1"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="連接埠" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox x:Name="SmtpPortBox" Grid.Row="2" Grid.Column="1" FontSize="12" Padding="4,3" Margin="8,0,0,4" Width="100" HorizontalAlignment="Left"
                                     Background="#2D2D2D" Foreground="#E1E1E1" BorderBrush="#444444" BorderThickness="1" Text="587"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="使用 SSL" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <CheckBox x:Name="UseSslCheck" Grid.Row="3" Grid.Column="1" Margin="8,0,0,4" VerticalAlignment="Center" IsChecked="True"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="使用者名稱" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox x:Name="SmtpUserBox" Grid.Row="4" Grid.Column="1" FontSize="12" Padding="4,3" Margin="8,0,0,4"
                                     Background="#2D2D2D" Foreground="#E1E1E1" BorderBrush="#444444" BorderThickness="1"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="密碼" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <PasswordBox x:Name="SmtpPassBox" Grid.Row="5" Grid.Column="1" FontSize="12" Padding="4,3" Margin="8,0,0,4"
                                         Background="#2D2D2D" Foreground="#E1E1E1" BorderBrush="#444444" BorderThickness="1"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="寄件者地址" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox x:Name="FromAddressBox" Grid.Row="6" Grid.Column="1" FontSize="12" Padding="4,3" Margin="8,0,0,0"
                                     Background="#2D2D2D" Foreground="#E1E1E1" BorderBrush="#444444" BorderThickness="1"/>
                        </Grid>

                        <TextBlock Text="預設收件人（多個以逗號或分號分隔）" FontSize="12" Margin="0,8,0,4"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBox x:Name="RecipientsBox" FontSize="12" Padding="4,3" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                 Background="#2D2D2D" Foreground="#E1E1E1" BorderBrush="#444444" BorderThickness="1"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="重試設定" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="最大重試次數" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox x:Name="RetryMaxBox" Grid.Row="0" Grid.Column="1" FontSize="12" Padding="4,3" Margin="8,0,0,4" Width="80" HorizontalAlignment="Left"
                                     Background="#2D2D2D" Foreground="#E1E1E1" BorderBrush="#444444" BorderThickness="1" Text="3"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="重試間隔 (秒)" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox x:Name="RetryDelayBox" Grid.Row="1" Grid.Column="1" FontSize="12" Padding="4,3" Margin="8,0,0,0" Width="80" HorizontalAlignment="Left"
                                     Background="#2D2D2D" Foreground="#E1E1E1" BorderBrush="#444444" BorderThickness="1" Text="30"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Padding="16">
                    <StackPanel>
                        <WrapPanel>
                            <Button x:Name="SaveNotificationBtn" Content="儲存設定" Style="{StaticResource ModernButton}"
                                    Height="30" FontSize="12" Padding="20,0" Margin="0,0,8,0"
                                    Click="SaveNotification_Click"/>
                            <Button x:Name="TestEmailBtn" Content="測試郵件" Style="{StaticResource SecondaryButton}"
                                    Height="30" FontSize="12" Padding="20,0"
                                    Click="TestEmail_Click"/>
                        </WrapPanel>
                        <TextBlock x:Name="NotificationStatus" Text="" FontSize="12" Margin="0,8,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Audit log panel -->
        <ScrollViewer Grid.Row="2" x:Name="AuditLogPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="稽核日誌" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                            <Button Grid.Column="1" Content="重新整理" Style="{StaticResource SecondaryButton}"
                                    Height="28" FontSize="11" Margin="0,0,8,0" Click="RefreshAuditLog_Click"/>
                            <Button Grid.Column="2" Content="匯出 CSV" Style="{StaticResource SecondaryButton}"
                                    Height="28" FontSize="11" Click="ExportCsv_Click"/>
                        </Grid>

                        <WrapPanel Margin="0,4,0,8">
                            <TextBlock Text="開始" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <DatePicker x:Name="AuditStartDate" Margin="4,0,12,0" FontSize="12" SelectedDate="{x:Static sys:DateTime.Today}" xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                            <TextBlock Text="結束" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <DatePicker x:Name="AuditEndDate" Margin="4,0,12,0" FontSize="12"/>
                            <TextBlock Text="分類" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <ComboBox x:Name="AuditCategoryFilter" Width="100" Margin="4,0,12,0" Style="{StaticResource ModernComboBox}"/>
                            <TextBlock Text="使用者" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <TextBox x:Name="AuditUserBox" Width="120" Margin="4,0,0,0" Style="{StaticResource ModernTextBox}"/>
                        </WrapPanel>

                        <DataGrid x:Name="AuditLogGrid" Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False" CanUserResizeRows="False" MaxHeight="480"
                                  IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0" SelectionMode="Single" SelectionUnit="FullRow"
                                  CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeColumns="True"
                                  ColumnHeaderStyle="{StaticResource ModernColumnHeader}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="時間" Binding="{Binding Timestamp, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" Width="130"/>
                                <DataGridTextColumn Header="層級" Binding="{Binding Severity}" Width="55"/>
                                <DataGridTextColumn Header="分類" Binding="{Binding Category}" Width="70"/>
                                <DataGridTextColumn Header="使用者" Binding="{Binding User}" Width="90"/>
                                <DataGridTextColumn Header="來源" Binding="{Binding Source}" Width="100"/>
                                <DataGridTextColumn Header="訊息" Binding="{Binding Message}" Width="*" MinWidth="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- FFmpeg panel -->
        <ScrollViewer Grid.Row="2" x:Name="FfmpegPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="FFmpeg" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="版本：" VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="FfmpegVersionText"
                                       Text="檢查中..." Foreground="{StaticResource TextBrush}"
                                       FontSize="12" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="DLL 路徑：" VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="FfmpegDllPathText"
                                       Text="檢查中..." Foreground="{StaticResource TextBrush}"
                                       FontSize="12" Margin="8,4,0,0" TextWrapping="NoWrap"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="DLL 數量：" VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="FfmpegDllCountText"
                                       Text="" Foreground="{StaticResource TextBrush}"
                                       FontSize="12" Margin="8,4,0,0"/>
                        </Grid>
                        <WrapPanel>
                            <Button x:Name="UpdateFfmpegBtn" Content="下載／更新 FFmpeg"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="28" FontSize="11" Padding="12,0"
                                    Click="UpdateFfmpeg_Click"/>
                            <Button Content="開啟 GitHub 釋出版本頁"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="28" FontSize="11" Padding="12,0" Margin="8,0,0,0"
                                    Click="OpenFfmpegGitHub_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Manual FFmpeg path -->
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="手動指定 FFmpeg" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock Text="指定已下載的 FFmpeg 資料夾或 .zip 壓縮檔，系統將驗證並複製到應用程式目錄。"
                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FfmpegManualPath" Style="{StaticResource ModernTextBox}"
                                     Text="" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="瀏覽..." Height="28" FontSize="11" Padding="12,0"
                                    Click="BrowseFfmpegPath_Click"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,0">
                            <Button x:Name="ImportFfmpegBtn" Content="匯入 FFmpeg"
                                    Style="{StaticResource ModernButton}"
                                    Height="28" FontSize="11" Padding="16,0"
                                    Click="ImportFfmpeg_Click"/>
                            <TextBlock x:Name="FfmpegImportStatus" Text=""
                                       FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- About Card -->
                <Border Style="{StaticResource CardBorder}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="關於" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock Text="HeliVMS — 智慧影像管理系統" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="版本：V1.0.0" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock Text="禾秝軟體開發團隊" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Recording schedule panel -->
        <ScrollViewer Grid.Row="2" x:Name="SchedulePanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="錄影排程設定" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                        <TextBlock Text="設定各攝影機的錄影與移動偵測排程規則。若無任何規則，預設為全天候錄影。"
                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="攝影機" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextBrush}" FontSize="13" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" x:Name="ScheduleCameraCombo" MinWidth="200"
                                      Style="{StaticResource ModernComboBox}"
                                      SelectionChanged="ScheduleCamera_Changed"/>
                        </Grid>
                        <ItemsControl x:Name="ScheduleRulesList" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" SelectedItem="{Binding Day}" MinWidth="70"
                                                      FontSize="12" Background="{StaticResource SurfaceBrush}"
                                                      Foreground="{StaticResource TextBrush}">
                                                <ComboBoxItem Content="週一"/>
                                                <ComboBoxItem Content="週二"/>
                                                <ComboBoxItem Content="週三"/>
                                                <ComboBoxItem Content="週四"/>
                                                <ComboBoxItem Content="週五"/>
                                                <ComboBoxItem Content="週六"/>
                                                <ComboBoxItem Content="週日"/>
                                            </ComboBox>
                                            <TextBox Grid.Column="1" Text="{Binding StartTime}" FontSize="12" MinWidth="60" Margin="4,0"/>
                                            <TextBox Grid.Column="2" Text="{Binding EndTime}" FontSize="12" MinWidth="60" Margin="4,0"/>
                                            <CheckBox Grid.Column="3" IsChecked="{Binding RecordingEnabled}" Content="錄影" FontSize="12" Margin="8,0"/>
                                            <CheckBox Grid.Column="4" IsChecked="{Binding MotionDetectionEnabled}" Content="偵測" FontSize="12" Margin="8,0"/>
                                            <Button Grid.Column="5" Content="✕" Width="24" Height="24" FontSize="10"
                                                    Background="Transparent" Foreground="{StaticResource SecondaryTextBrush}"
                                                    BorderThickness="0" Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <WrapPanel Margin="0,12,0,0">
                            <Button x:Name="AddScheduleRuleBtn" Content="+ 新增規則"
                                    Style="{StaticResource SecondaryButton}" Height="28" FontSize="11" Padding="12,0"
                                    Click="AddScheduleRule_Click"/>
                            <Button x:Name="SaveScheduleBtn" Content="儲存排程"
                                    Style="{StaticResource ModernButton}" Height="28" FontSize="11" Padding="16,0" Margin="8,0,0,0"
                                    Click="SaveSchedule_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Schedule exceptions section -->
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="例外日期" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
                        <TextBlock Text="設定特定日期覆寫排程規則（如假日全天錄影或暫停錄影）"
                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="ScheduleExceptionsList" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <DatePicker Grid.Column="0" SelectedDate="{Binding Date}" FontSize="12"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        Foreground="{StaticResource TextBrush}"/>
                                            <ComboBox Grid.Column="1" MinWidth="90" Margin="8,0"
                                                      FontSize="12" Background="{StaticResource SurfaceBrush}"
                                                      Foreground="{StaticResource TextBrush}"
                                                      SelectedIndex="{Binding Override}">
                                                <ComboBoxItem Content="暫停錄影"/>
                                                <ComboBoxItem Content="全天錄影"/>
                                                <ComboBoxItem Content="依排程"/>
                                            </ComboBox>
                                            <TextBox Grid.Column="2" Text="{Binding Label}" FontSize="12" MinWidth="80" Margin="4,0"
                                                     Background="{StaticResource SurfaceBrush}"
                                                     Foreground="{StaticResource TextBrush}"/>
                                            <Button Grid.Column="3" Content="✕" Width="24" Height="24" FontSize="10"
                                                    Background="Transparent" Foreground="{StaticResource SecondaryTextBrush}"
                                                    BorderThickness="0" Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <WrapPanel>
                            <Button x:Name="AddScheduleExceptionBtn" Content="+ 新增例外日期"
                                    Style="{StaticResource SecondaryButton}" Height="28" FontSize="11" Padding="12,0"
                                    Click="AddScheduleException_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Backup & restore panel -->
        <ScrollViewer Grid.Row="2" x:Name="BackupPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="資料備份" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock Text="備份所有設定檔（攝影機、事件規則、排程、群組等 JSON 資料）。"
                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="CreateBackupBtn" Content="建立備份"
                                    Style="{StaticResource ModernButton}" Height="32" FontSize="12" Padding="20,0"
                                    Click="CreateBackup_Click"/>
                            <TextBlock Grid.Column="1" x:Name="BackupStatusText"
                                       Text="" FontSize="11" VerticalAlignment="Center"
                                       Margin="12,0,0,0" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="備份清單" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock Text="最近的備份檔案。按一下可直接還原該備份的所有設定。"
                                   Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <ListBox x:Name="BackupListBox" MaxHeight="300"
                                 Background="{StaticResource SurfaceBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 Margin="0,0,0,8">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <WrapPanel>
                            <Button x:Name="RestoreBackupBtn" Content="還原選取備份"
                                    Style="{StaticResource ModernButton}" Height="28" FontSize="11" Padding="16,0"
                                    Click="RestoreBackup_Click"/>
                            <Button x:Name="RefreshBackupListBtn" Content="重新整理"
                                    Style="{StaticResource SecondaryButton}" Height="28" FontSize="11" Padding="12,0" Margin="8,0,0,0"
                                    Click="RefreshBackupList_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
