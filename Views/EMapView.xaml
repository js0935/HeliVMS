<UserControl x:Class="HeliVMS.Views.EMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="LoadMapBtn" Content="載入地圖" Style="{StaticResource SecondaryButton}"
                        Height="28" Padding="8,0" Margin="0,0,4,0" Click="LoadMap_Click"/>
                <Button x:Name="ClearMapBtn" Content="清除地圖" Style="{StaticResource SecondaryButton}"
                        Height="28" Padding="8,0" Margin="4,0" Click="ClearMap_Click"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>
                <Button x:Name="AddFloorBtn" Content="+ 樓層" Style="{StaticResource SecondaryButton}"
                        Height="28" Padding="8,0" Margin="0,0,4,0" Click="AddFloor_Click"/>
                <Button x:Name="RenameFloorBtn" Content="重新命名" Style="{StaticResource SecondaryButton}"
                        Height="28" Padding="8,0" Margin="4,0" Click="RenameFloor_Click"/>
                <Button x:Name="RemoveFloorBtn" Content="刪除樓層" Style="{StaticResource SecondaryButton}"
                        Height="28" Padding="8,0" Margin="4,0" Click="RemoveFloor_Click"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>
                <TextBlock Text="左鍵拖曳移動攝影機 ・ 滾輪縮放 ・ 雙擊預覽 ・ 右鍵選單"
                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Floor tabs -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Padding="8,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="FloorTabBar" Orientation="Horizontal"/>
            </ScrollViewer>
        </Border>

        <!-- Map Canvas Area -->
        <Border Grid.Row="2" Margin="4" Background="{DynamicResource SurfaceBrush}"
                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                ClipToBounds="True">
            <Canvas x:Name="MapCanvas" Background="Transparent"
                    MouseWheel="MapCanvas_MouseWheel"
                    MouseLeftButtonDown="MapCanvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="MapCanvas_MouseLeftButtonUp"
                    MouseMove="MapCanvas_MouseMove"
                    ContextMenuOpening="MapCanvas_ContextMenuOpening">
                <Canvas.ContextMenu>
                    <ContextMenu x:Name="MapContextMenu"/>
                </Canvas.ContextMenu>
                <Canvas x:Name="MapContainer" Canvas.Left="0" Canvas.Top="0">
                    <Image x:Name="MapImage" Canvas.Left="0" Canvas.Top="0"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="None" Opacity="0.9"/>
                </Canvas>
            </Canvas>
        </Border>
    </Grid>
</UserControl>
