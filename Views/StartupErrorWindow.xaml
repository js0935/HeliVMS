<Window x:Class="HeliVMS.Views.StartupErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HeliVMS е•ҹеӢ•йҢҜиӘӨ"
        Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Background="{StaticResource BackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="HeliVMS е•ҹеӢ•еӨұж•—" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource ErrorBrush}" Margin="0,0,0,16"/>
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="6"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <ScrollViewer Padding="12">
                <TextBox x:Name="ErrorDetailsBox" Text="" IsReadOnly="True"
                         TextWrapping="Wrap" FontSize="12" FontFamily="Consolas"
                         Foreground="{StaticResource TextBrush}"
                         Background="Transparent" BorderThickness="0"/>
            </ScrollViewer>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="иӨҮиЈҪйҢҜиӘӨиіҮиЁҠ" Width="120" Height="32" Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButton}" Click="CopyError_Click"/>
            <Button Content="й—ңй–ү" Width="80" Height="32"
                    Style="{StaticResource ModernButton}" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>