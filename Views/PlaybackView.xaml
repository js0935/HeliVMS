<UserControl x:Class="HeliVMS.Views.PlaybackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:controls="clr-namespace:HeliVMS.Controls"
             xmlns:local="clr-namespace:HeliVMS.Views"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════ Row 0: Toolbar ═══════ -->
        <Border Grid.Row="0" x:Name="ToolbarRow" Style="{StaticResource CardBorder}"
                Padding="12,8" Margin="12,12,12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="錄影回放"
                           Style="{StaticResource PageHeader}" FontSize="20"
                           Margin="0" VerticalAlignment="Center"/>

                <Separator Grid.Column="1"
                           Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="12,0"/>

                <TextBlock Grid.Column="2" Text="日期" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="11" FontWeight="SemiBold" Margin="0,0,4,0"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button x:Name="PrevDayBtn"
                            Style="{StaticResource SecondaryButton}"
                            Height="28" Width="26" FontSize="9"
                            Padding="0" Margin="0,0,2,0"
                            Click="PrevDayBtn_Click" ToolTip="前一天">
                        <Path Data="{StaticResource IconChevronLeft}" Fill="{DynamicResource TextBrush}" Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                    <DatePicker x:Name="FilterDatePicker"
                                 SelectedDateChanged="FilterDatePicker_SelectedDateChanged"
                                 Width="108"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    <Button x:Name="NextDayBtn"
                            Style="{StaticResource SecondaryButton}"
                            Height="28" Width="26" FontSize="9"
                            Padding="0" Margin="2,0,0,0"
                            Click="NextDayBtn_Click" ToolTip="後一天">
                        <Path Data="{StaticResource IconChevronRight}" Fill="{DynamicResource TextBrush}" Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="4" Text="時" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="11" FontWeight="SemiBold" Margin="8,0,4,0"/>
                <ComboBox Grid.Column="5" x:Name="PlaybackHourCombo"
                          Style="{StaticResource ModernComboBox}"
                          SelectedIndex="0" Width="60" Height="26" FontSize="11">
                    <sys:String>00</sys:String><sys:String>01</sys:String><sys:String>02</sys:String><sys:String>03</sys:String>
                    <sys:String>04</sys:String><sys:String>05</sys:String><sys:String>06</sys:String><sys:String>07</sys:String>
                    <sys:String>08</sys:String><sys:String>09</sys:String><sys:String>10</sys:String><sys:String>11</sys:String>
                    <sys:String>12</sys:String><sys:String>13</sys:String><sys:String>14</sys:String><sys:String>15</sys:String>
                    <sys:String>16</sys:String><sys:String>17</sys:String><sys:String>18</sys:String><sys:String>19</sys:String>
                    <sys:String>20</sys:String><sys:String>21</sys:String><sys:String>22</sys:String><sys:String>23</sys:String>
                </ComboBox>

                <Button Grid.Column="6" x:Name="LoadTimeRangeBtn"
                        Content="載入" FontSize="11" FontWeight="SemiBold"
                        Style="{StaticResource ModernButton}"
                        Height="28" Padding="12,0" Margin="6,0,0,0"
                        Click="LoadTimeRangeBtn_Click"/>

                <Button Grid.Column="7" x:Name="PlayAllBtn"
                        Content="▶  全部播放" FontSize="11" FontWeight="Bold"
                        Style="{StaticResource ModernButton}"
                        Height="28" Padding="12,0" Margin="6,0,0,0"
                        Click="PlayAllBtn_Click" ToolTip="全選所有頻道並載入目前時段的錄影播放"
                        Background="{DynamicResource SuccessBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderBrush="{DynamicResource SuccessBrush}"/>

                <!-- Right-side actions -->
                <StackPanel Grid.Column="13" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="PlayingCountBadge"
                            Background="{DynamicResource SuccessBrush}" Opacity="0.2"
                            CornerRadius="4" Padding="8,3" Margin="0,0,6,0"
                            VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock x:Name="PlayingCountText" Text=""
                                   Foreground="{DynamicResource SuccessBrush}"
                                   FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="SyncIndicator"
                            Background="{DynamicResource RecordingContinuousBrush}" Opacity="0.2"
                            CornerRadius="4" Padding="8,3" Margin="0,0,6,0"
                            VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock x:Name="SyncIndicatorText" Text=""
                                   Foreground="{DynamicResource RecordingContinuousBrush}"
                                   FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="{DynamicResource SecondarySurfaceBrush}"
                            CornerRadius="4" Padding="10,3" Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ClockDateText"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ClockTimeText"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="SnapshotBtn" Content="拍照"
                            Style="{StaticResource SecondaryButton}"
                            Height="28" FontSize="11" Padding="10,0"
                            Margin="0,0,4,0" Click="SnapshotBtn_Click"/>
                    <Button x:Name="LayoutBtn"
                            Style="{StaticResource SecondaryButton}"
                            Height="28" FontSize="11" Padding="8,0" Margin="0,0,4,0"
                            Click="LayoutBtn_Click" ToolTip="切換版面配置">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLayout}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                            <TextBlock Text="Auto" Margin="4,0,0,0" FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BackupBtn" Content="備份錄影"
                            Style="{StaticResource SecondaryButton}"
                            Height="28" FontSize="11" Padding="10,0" Margin="0,0,4,0"
                            Click="BackupBtn_Click"/>
                    <Button x:Name="RefreshBtn" Content="重新整理"
                            Style="{StaticResource SecondaryButton}"
                            Height="28" FontSize="11" Padding="10,0"
                            Click="RefreshBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ Row 1: Main (Left sidebar + Video grid) ═══════ -->
        <Grid Grid.Row="1" Margin="12,0,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftSidebarColumn" Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left sidebar: Search + Channel -->
            <Border Grid.Column="0" x:Name="SearchPanel"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Margin="0,0,8,0" Visibility="Visible">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search header -->
                    <Border Grid.Row="0" Padding="12,10,12,6">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSearch}"
                                  Fill="{DynamicResource TextBrush}"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="搜尋錄影"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- Quick time presets -->
                    <WrapPanel Grid.Row="1" Margin="12,0,12,6">
                        <Button Content="本日" Style="{StaticResource SecondaryButton}"
                                Height="22" FontSize="10" Padding="8,0" Margin="0,0,2,2"
                                Click="SearchPresetToday_Click"/>
                        <Button Content="1H" Style="{StaticResource SecondaryButton}"
                                Height="22" FontSize="10" Padding="8,0" Margin="0,0,2,2"
                                Click="SearchPreset1H_Click"/>
                        <Button Content="6H" Style="{StaticResource SecondaryButton}"
                                Height="22" FontSize="10" Padding="8,0" Margin="0,0,2,2"
                                Click="SearchPreset6H_Click"/>
                        <Button Content="24H" Style="{StaticResource SecondaryButton}"
                                Height="22" FontSize="10" Padding="8,0" Margin="0,0,2,2"
                                Click="SearchPreset24H_Click"/>
                        <Button Content="本週" Style="{StaticResource SecondaryButton}"
                                Height="22" FontSize="10" Padding="8,0"
                                Click="SearchPresetWeek_Click"/>
                    </WrapPanel>

                    <!-- Time range: from -->
                    <WrapPanel Grid.Row="2" Margin="12,0,12,4">
                        <TextBlock Text="從" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,4,0"/>
                        <DatePicker x:Name="SearchFromDate" Width="100" Height="24" FontSize="11"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"/>
                        <TextBox x:Name="SearchFromHour" Text="00" Width="28" Height="24" FontSize="10"
                                 HorizontalContentAlignment="Center" Margin="2,0,0,0"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                        <TextBlock Text=":" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="1,0"/>
                        <TextBox x:Name="SearchFromMinute" Text="00" Width="28" Height="24" FontSize="10"
                                 HorizontalContentAlignment="Center"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                        <TextBlock Text=":" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="1,0"/>
                        <TextBox x:Name="SearchFromSecond" Text="00" Width="28" Height="24" FontSize="10"
                                 HorizontalContentAlignment="Center"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </WrapPanel>

                    <!-- Time range: to -->
                    <WrapPanel Grid.Row="3" Margin="12,0,12,6">
                        <TextBlock Text="至" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,4,0"/>
                        <DatePicker x:Name="SearchToDate" Width="100" Height="24" FontSize="11"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"/>
                        <TextBox x:Name="SearchToHour" Text="23" Width="28" Height="24" FontSize="10"
                                 HorizontalContentAlignment="Center" Margin="2,0,0,0"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                        <TextBlock Text=":" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="1,0"/>
                        <TextBox x:Name="SearchToMinute" Text="59" Width="28" Height="24" FontSize="10"
                                 HorizontalContentAlignment="Center"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                        <TextBlock Text=":" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="1,0"/>
                        <TextBox x:Name="SearchToSecond" Text="59" Width="28" Height="24" FontSize="10"
                                 HorizontalContentAlignment="Center"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </WrapPanel>

                    <!-- Filters -->
                    <WrapPanel Grid.Row="4" Margin="12,0,12,6">
                        <TextBlock Text="類型:" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,4,0"/>
                        <ComboBox x:Name="SearchTypeFilter" Width="70" Height="22" FontSize="10"
                                  SelectedIndex="0"
                                  Background="{DynamicResource InputBackgroundBrush}"
                                  Foreground="{DynamicResource TextBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBoxItem Content="全部"/>
                            <ComboBoxItem Content="連續"/>
                            <ComboBoxItem Content="動態"/>
                            <ComboBoxItem Content="警報"/>
                        </ComboBox>
                        <TextBox x:Name="SearchCameraFilter" Width="70" Height="22" FontSize="10"
                                 ToolTip="頻道編號或名稱篩選"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Margin="4,0,0,0"
                                 KeyDown="SearchInput_KeyDown"/>
                        <CheckBox x:Name="SearchMotionFilter" Content="僅動態"
                                  FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                  VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </WrapPanel>

                    <!-- Buttons -->
                    <WrapPanel Grid.Row="5" Margin="12,0,12,6">
                        <Button x:Name="ExecuteSearchBtn" Content="搜尋"
                                Style="{StaticResource SecondaryButton}"
                                Height="24" FontSize="10" Padding="10,0"
                                Click="ExecuteSearchBtn_Click"/>
                        <Button x:Name="SearchClearFiltersBtn" Content="清除"
                                Style="{StaticResource SecondaryButton}"
                                Height="24" FontSize="10" Padding="6,0" Margin="4,0,0,0"
                                Click="SearchClearFiltersBtn_Click"/>
                        <Button x:Name="CloseSearchBtn"
                                Style="{StaticResource SecondaryButton}"
                                Height="24" Width="24" Margin="4,0,0,0" Padding="0"
                                Click="CloseSearchBtn_Click" ToolTip="關閉搜尋">
                            <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextBrush}" Width="8" Height="8" Stretch="Uniform"/>
                        </Button>
                        <TextBlock x:Name="SearchStatusText" Text="" FontSize="10"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                   Visibility="Collapsed"/>
                    </WrapPanel>

                    <!-- Separator -->
                    <Border Grid.Row="6" Height="1" Background="{DynamicResource BorderBrush}" Margin="0,2,0,4"/>

                    <!-- Channel header -->
                    <Border Grid.Row="7" Padding="12,4,12,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconCamera}"
                                      Fill="{DynamicResource TextBrush}"
                                      Width="12" Height="12" Stretch="Uniform"
                                      Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="頻道選擇"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" x:Name="ChannelCountText" Text="0 / 16 路"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Button Grid.Column="2" x:Name="CollapseChannelBtn"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="18" Width="18" FontSize="7"
                                    Padding="0" Margin="0"
                                    Click="CollapseChannelBtn_Click"
                                    ToolTip="隱藏側欄">
                                <Path Data="{StaticResource IconChevronLeft}" Fill="{DynamicResource TextBrush}" Width="8" Height="8" Stretch="Uniform"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Channel quick buttons -->
                    <WrapPanel Grid.Row="8" Margin="12,0,12,4">
                        <Button x:Name="SelectAllBtn" Content="全選"
                                Style="{StaticResource SecondaryButton}"
                                Height="20" FontSize="9" Padding="6,0" Margin="0,0,4,0"
                                Click="SelectAllBtn_Click"/>
                        <Button x:Name="ClearAllBtn" Content="清除"
                                Style="{StaticResource SecondaryButton}"
                                Height="20" FontSize="9" Padding="6,0"
                                Click="ClearAllBtn_Click"/>
                    </WrapPanel>

                    <!-- Channel search -->
                    <Border Grid.Row="9" Margin="12,0,12,4"
                            Background="{DynamicResource InputBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="6,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ChannelSearchBox" Text="" FontSize="10"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextBrush}"
                                     TextChanged="ChannelSearchBox_TextChanged"/>
                            <Path Grid.Column="1" Data="{StaticResource IconSearch}"
                                  Fill="{DynamicResource SecondaryTextBrush}"
                                  Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Channel list -->
                    <ScrollViewer Grid.Row="10" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="Transparent" BorderThickness="0">
                        <StackPanel x:Name="ChannelListPanel" Margin="4,0"/>
                    </ScrollViewer>

                    <!-- Search results overlay (covers channel list area) -->
                    <Border x:Name="SearchResultOverlay" Grid.Row="7" Grid.RowSpan="4"
                            Background="{DynamicResource SurfaceBrush}"
                            Visibility="Collapsed" Panel.ZIndex="10"
                            BorderThickness="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="12,8,12,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SearchResultCount" Text="0" FontSize="10"
                                           Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" x:Name="BatchExportBtn" Content="匯出選取"
                                        Style="{StaticResource SecondaryButton}" Height="22" FontSize="9"
                                        Padding="8,0" Visibility="Collapsed"
                                        Click="BatchExportBtn_Click"/>
                            </Grid>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Background="Transparent" BorderThickness="0" Margin="4,0,4,4">
                                <StackPanel x:Name="SearchResultList"/>
                            </ScrollViewer>
                            <Border x:Name="SearchLoadingOverlay" Grid.RowSpan="2"
                                    Background="{DynamicResource SurfaceBrush}" Opacity="0.8"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="SearchLoadingText" Text="搜尋中…"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Bottom status -->
                    <Border Grid.Row="11" Padding="10,4"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource BorderBrush}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ChannelStatusText" Text="64 頻道"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="9" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" x:Name="RefreshChannelBtn"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="18" Width="18" Padding="0"
                                        Click="RefreshBtn_Click">
                                    <Path Data="{StaticResource IconRefresh}" Fill="{DynamicResource TextBrush}" Width="10" Height="10" Stretch="Uniform"/>
                                </Button>
                            </Grid>
                            <TextBlock x:Name="StorageStatusText" Text=""
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="9" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Video area -->
            <Grid Grid.Column="1">
                <!-- Expand button (hidden when sidebar open) -->
                <Button x:Name="ExpandChannelBtn"
                        Style="{StaticResource SecondaryButton}"
                        Width="16" Height="40" FontSize="8"
                        Padding="0" Margin="0"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Visibility="Collapsed"
                        Click="ExpandChannelBtn_Click"
                        ToolTip="顯示側欄">
                    <Path Data="{StaticResource IconChevronRight}" Fill="{DynamicResource TextBrush}" Width="6" Height="6" Stretch="Uniform"/>
                </Button>

                <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="8"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

                <Grid x:Name="PlaybackGrid" Visibility="Collapsed"/>

                <!-- Empty state -->
                <Border x:Name="EmptyPrompt" Background="Transparent" CornerRadius="8" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconCamera}" Fill="{DynamicResource SecondaryTextBrush}"
                              Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.5"/>
                        <TextBlock Text="選擇日期與頻道開始回放"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,12,0,4" HorizontalAlignment="Center"/>
                        <TextBlock Text="左側勾選已指派的攝影機頻道，選取日期後自動載入錄影資料"
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"
                                   HorizontalAlignment="Center" Opacity="0.7"/>
                        <Button x:Name="EmptyPlayAllBtn" Content="▶  快速全部播放  (Ctrl+P)"
                                Style="{StaticResource ModernButton}" Height="32" Padding="16,0"
                                Margin="0,12,0,0" FontSize="12" FontWeight="Bold"
                                Background="{DynamicResource SuccessBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderBrush="{DynamicResource SuccessBrush}"
                                Click="PlayAllBtn_Click"
                                ToolTip="自動選取已指派攝影機的頻道，載入今日錄影播放"/>
                    </StackPanel>
                </Border>

                <!-- Loading overlay -->
                <Border x:Name="VideoLoadingOverlay"
                        Background="{DynamicResource SurfaceBrush}" Opacity="0.8"
                        CornerRadius="8" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="VideoLoadingText" Text="載入中…"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Search results area (inside left sidebar now, but keep overlay for backward compat) -->

                <!-- Bookmark panel -->
                <Border x:Name="BookmarkPanel" Grid.Column="1"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Width="0"
                        HorizontalAlignment="Right" VerticalAlignment="Stretch"
                        Margin="0,4,4,4" Visibility="Collapsed" Panel.ZIndex="40">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center">書籤</TextBlock>
                                <TextBlock x:Name="BookmarkCountBadge" Text="0" FontSize="9"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="ClearBookmarksBtn"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="18" FontSize="8" Padding="4,0"
                                    Click="ClearBookmarksBtn_Click" ToolTip="清除全部書籤">清除</Button>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Background="Transparent" BorderThickness="0">
                            <StackPanel x:Name="BookmarkListPanel" Margin="4,0"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ClearBookmarksBtn click handler -->
                <!-- Performance monitor -->
                <Border x:Name="PerfPanel"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Width="360"
                        HorizontalAlignment="Right" VerticalAlignment="Stretch"
                        Margin="0,4,4,4" Visibility="Collapsed" Panel.ZIndex="50">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="8,6"
                                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="效能監控" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="PerfSummaryText" Text=""
                                           FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Button Grid.Column="2" x:Name="ExportPerfBtn" FontSize="10"
                                        Width="18" Height="18" Padding="0" BorderThickness="0"
                                        Background="Transparent" Foreground="{DynamicResource SecondaryTextBrush}"
                                        Click="ExportPerfBtn_Click" ToolTip="匯出 CSV">
                                    <Path Data="{StaticResource IconExport}" Fill="{DynamicResource SecondaryTextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                                </Button>
                                <Button Grid.Column="3" x:Name="ClosePerfBtn" Width="16" Height="16"
                                        Padding="0" BorderThickness="0" Background="Transparent"
                                        Click="ClosePerfBtn_Click" ToolTip="關閉">
                                    <Path Data="{StaticResource IconClose}" Fill="{DynamicResource SecondaryTextBrush}" Width="8" Height="8" Stretch="Uniform"/>
                                </Button>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource DividerBrush}">
                            <Grid Margin="4,2,4,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/><ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="32"/><ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="24"/><ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="CH" FontSize="8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="頻道" FontSize="8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="FPS" FontSize="8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="丟棄" FontSize="8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="滯" FontSize="8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="5" Text="延遲" FontSize="8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="6" Text="PTS" FontSize="8" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Background="Transparent" BorderThickness="0">
                            <StackPanel x:Name="PerfListPanel" Margin="4,0"/>
                        </ScrollViewer>
                </Grid>
            </Border>
            </Grid>
        </Grid>

        <!-- ═══════ Row 2: NxTimeline ═══════ -->
        <Border Grid.Row="2" x:Name="TimelineArea" Style="{StaticResource CardBorder}"
                Padding="0" Margin="12,0,12,4"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Timeline controls bar -->
                <Border Grid.Row="0" Padding="8,4,8,3"
                        BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="顯示" FontSize="10"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ToggleButton Grid.Column="1" x:Name="ToggleContinuous"
                                       Content="連續" IsChecked="True"
                                       Height="20" FontSize="10" Padding="6,0"
                                       Margin="0,0,2,0" Cursor="Hand"
                                       BorderThickness="1"
                                       BorderBrush="{DynamicResource RecordingContinuousBrush}"
                                       Background="{DynamicResource RecordingContinuousBrush}"
                                       Checked="ToggleTypeFilter" Unchecked="ToggleTypeFilter"
                                       Tag="0"/>
                        <ToggleButton Grid.Column="2" x:Name="ToggleMotion"
                                       Content="動態" IsChecked="True"
                                       Height="20" FontSize="10" Padding="6,0"
                                       Margin="0,0,2,0" Cursor="Hand"
                                       BorderThickness="1"
                                       BorderBrush="{DynamicResource RecordingMotionBrush}"
                                       Background="{DynamicResource RecordingMotionBrush}"
                                       Checked="ToggleTypeFilter" Unchecked="ToggleTypeFilter"
                                       Tag="1"/>
                        <ToggleButton Grid.Column="3" x:Name="ToggleAlarm"
                                       Content="警報" IsChecked="True"
                                       Height="20" FontSize="10" Padding="6,0"
                                       Margin="0,0,2,0" Cursor="Hand"
                                       BorderThickness="1"
                                       BorderBrush="{DynamicResource RecordingAlarmBrush}"
                                       Background="{DynamicResource RecordingAlarmBrush}"
                                       Checked="ToggleTypeFilter" Unchecked="ToggleTypeFilter"
                                       Tag="2"/>
                        <ToggleButton Grid.Column="4" x:Name="ToggleAi"
                                       Content="AI" IsChecked="True"
                                       Height="20" FontSize="10" Padding="6,0"
                                       Cursor="Hand" BorderThickness="1"
                                       BorderBrush="{DynamicResource RecordingAiBrush}"
                                       Background="{DynamicResource RecordingAiBrush}"
                                       Checked="ToggleTypeFilter" Unchecked="ToggleTypeFilter"
                                       Tag="3"/>

                        <TextBlock Grid.Column="5" x:Name="TimelineStatsText" Text=""
                                   FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>

                        <StackPanel Grid.Column="7" Orientation="Horizontal">
                            <Button x:Name="TimelineZoomInBtn"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="20" Width="22" FontSize="12" Padding="0"
                                    Click="TimelineZoomInBtn_Click"
                                    ToolTip="放大時間軸">
                                <Path Data="{StaticResource IconPlus}" Fill="{DynamicResource TextBrush}" Width="10" Height="10" Stretch="Uniform"/>
                            </Button>
                            <TextBlock x:Name="TimelineZoomLabel" Text="24h"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center" Margin="4,0"/>
                            <Button x:Name="TimelineZoomOutBtn"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="20" Width="22" FontSize="12" Padding="0"
                                    Margin="2,0,0,0"
                                    Click="TimelineZoomOutBtn_Click"
                                    ToolTip="縮小時間軸">
                                <Path Data="{StaticResource IconMinus}" Fill="{DynamicResource TextBrush}" Width="10" Height="10" Stretch="Uniform"/>
                            </Button>
                            <Button x:Name="TimelineResetZoomBtn"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="20" Padding="4,0" FontSize="9"
                                    Margin="4,0,0,0"
                                    Click="TimelineResetZoomBtn_Click"
                                    ToolTip="重置縮放顯示 24 小時">
                                <TextBlock Text="24h" FontSize="9" Foreground="{DynamicResource TextBrush}"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <controls:NxTimeline x:Name="Timeline" Grid.Row="1" Height="180"
                                     Margin="0" Background="Transparent"
                                     BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- ═══════ Row 3: Playback controls ═══════ -->
        <Border x:Name="ControlsRow" Grid.Row="3" Style="{StaticResource CardBorder}"
                Padding="10,6" Margin="12,0,12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="JumpStartBtn"
                        Style="{StaticResource SecondaryButton}"
                        Height="28" Width="30"
                        Click="JumpStartBtn_Click" ToolTip="跳到開頭 (Ctrl+←)">
                    <Path Data="{StaticResource IconSkipBack}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                </Button>
                <Button Grid.Column="1" x:Name="StepBackBtn"
                        Style="{StaticResource SecondaryButton}"
                        Height="28" Width="30" Margin="2,0,0,0"
                        Click="StepBackBtn_Click" ToolTip="上一幀 (←)">
                    <Path Data="{StaticResource IconRewind}" Fill="{DynamicResource TextBrush}" Width="11" Height="11" Stretch="Uniform"/>
                </Button>

                <Border Grid.Column="2" Background="{DynamicResource SecondarySurfaceBrush}"
                        CornerRadius="4" Margin="2,0,0,0" Padding="1">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PlayBtn" Style="{StaticResource ModernButton}"
                                Height="26" Width="32" FontSize="11" BorderThickness="0"
                                Click="PlayBtn_Click" ToolTip="播放 (Space)">
                            <Path Data="{StaticResource IconPlay}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                        <Border Width="1" Background="{DynamicResource BorderBrush}"/>
                        <Button x:Name="PauseBtn" Style="{StaticResource SecondaryButton}"
                                Height="26" Width="32" BorderThickness="0"
                                Click="PauseBtn_Click" ToolTip="暫停 (Space)">
                            <Path Data="{StaticResource IconPause}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Border>

                <Button Grid.Column="4" x:Name="StepFwdBtn"
                        Style="{StaticResource SecondaryButton}"
                        Height="28" Width="30" Margin="2,0,0,0"
                        Click="StepFwdBtn_Click" ToolTip="下一幀 (→)">
                    <Path Data="{StaticResource IconFastForward}" Fill="{DynamicResource TextBrush}" Width="11" Height="11" Stretch="Uniform"/>
                </Button>
                <Button Grid.Column="5" x:Name="JumpEndBtn"
                        Style="{StaticResource SecondaryButton}"
                        Height="28" Width="30" Margin="2,0,0,0"
                        Click="JumpEndBtn_Click" ToolTip="跳到結尾 (Ctrl+→)">
                    <Path Data="{StaticResource IconSkipForward}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                </Button>

                <Button Grid.Column="6" x:Name="JumpPrevRecBtn"
                        Style="{StaticResource SecondaryButton}"
                        Height="28" Width="30" Margin="2,0,0,0"
                        Click="JumpPrevRecBtn_Click" ToolTip="跳到前一區段 (Ctrl+Shift+←)">
                    <Path Data="{StaticResource IconRewind}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                </Button>
                <Button Grid.Column="7" x:Name="JumpNextRecBtn"
                        Style="{StaticResource SecondaryButton}"
                        Height="28" Width="30" Margin="2,0,0,0"
                        Click="JumpNextRecBtn_Click" ToolTip="跳到後一區段 (Ctrl+Shift+→)">
                    <Path Data="{StaticResource IconFastForward}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                </Button>
                <Button Grid.Column="8" x:Name="StopBtn"
                        Style="{StaticResource SecondaryButton}"
                        Height="28" Width="30" Margin="2,0,0,0"
                        Click="StopBtn_Click" ToolTip="停止">
                    <Path Data="{StaticResource IconStop}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                </Button>

                <Separator Grid.Column="9"
                           Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>

                <TextBlock Grid.Column="10" Text="速度" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="10" FontWeight="SemiBold" Margin="0,0,2,0"/>
                <ComboBox Grid.Column="11" x:Name="SpeedCombo"
                          Style="{StaticResource ModernComboBox}"
                          SelectedIndex="2"
                          SelectionChanged="SpeedCombo_SelectionChanged"
                          Width="70" Height="24">
                    <ComboBoxItem Content="0.25x"/><ComboBoxItem Content="0.5x"/>
                    <ComboBoxItem Content="1x"/><ComboBoxItem Content="2x"/>
                    <ComboBoxItem Content="4x"/><ComboBoxItem Content="8x"/>
                    <ComboBoxItem Content="16x"/><ComboBoxItem Content="32x"/>
                </ComboBox>

                <Border x:Name="LoopPanel" Grid.Column="12" CornerRadius="4" Margin="4,0,0,0" Padding="1,0"
                        Background="{DynamicResource SecondarySurfaceBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="LoopSetABtn" Content="A" Style="{StaticResource SecondaryButton}"
                                Height="24" Width="24" FontSize="9" FontWeight="Bold"
                                Margin="1,0" Padding="0"
                                Click="LoopSetABtn_Click" ToolTip="設定循環起點 A (I)"/>
                        <Button x:Name="LoopSetBBtn" Content="B" Style="{StaticResource SecondaryButton}"
                                Height="24" Width="24" FontSize="9" FontWeight="Bold"
                                Margin="1,0" Padding="0"
                                Click="LoopSetBBtn_Click" ToolTip="設定循環終點 B (O)"/>
                        <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="2,0"/>
                        <Button x:Name="LoopToggleBtn" Style="{StaticResource SecondaryButton}"
                                Height="24" Width="24" FontSize="10" FontWeight="Bold"
                                Margin="1,0" Padding="0"
                                Click="LoopToggleBtn_Click" ToolTip="啟用/停用循環播放 (L)">
                            <Path Data="{StaticResource IconLoop}" Fill="{DynamicResource TextBrush}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                        <Button x:Name="LoopClearBtn" Style="{StaticResource SecondaryButton}"
                                Height="24" Width="14" Margin="1,0" Padding="0"
                                Click="LoopClearBtn_Click" ToolTip="清除 A-B 循環">
                            <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextBrush}" Width="7" Height="7" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Column="13" Background="{DynamicResource SecondarySurfaceBrush}"
                        CornerRadius="4" Padding="8,3" Margin="6,0,0,0">
                    <TextBlock x:Name="PlaybackTimeText"
                               Text="--:--:-- / --:--:--"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="11" FontWeight="SemiBold" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </Border>

                <Button Grid.Column="14" x:Name="StopAllBtn" Content="全部停止"
                        Style="{StaticResource SecondaryButton}"
                        Height="26" FontSize="10" Padding="8,0"
                        Margin="4,0,0,0" FontWeight="SemiBold"
                        Foreground="{DynamicResource ErrorBrush}"
                        Click="StopAllBtn_Click"/>
                <Button Grid.Column="15" x:Name="BookmarkBtn"
                        Style="{StaticResource SecondaryButton}"
                        Height="26" Width="28" Margin="2,0,0,0"
                        Click="BookmarkBtn_Click" ToolTip="標記書籤 (B)">
                    <Grid>
                        <Path x:Name="BookmarkIcon" Data="{StaticResource IconBookmark}"
                              Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        <TextBlock x:Name="BookmarkFeedback" Text="" Visibility="Collapsed"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Grid.Column="16" x:Name="BookmarkListBtn"
                        Style="{StaticResource SecondaryButton}"
                        Height="26" Width="28" FontSize="10" Padding="0"
                        Click="BookmarkListBtn_Click" ToolTip="書籤列表">
                    <Path x:Name="BookmarkListIcon" Data="{StaticResource IconBookmark}"
                          Fill="{DynamicResource SecondaryTextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                </Button>
                <Button Grid.Column="17" x:Name="ExportClipBtn" Content="匯出"
                        Style="{StaticResource SecondaryButton}"
                        Height="26" FontSize="10" Padding="8,0" Margin="2,0,0,0"
                        IsEnabled="False"
                        Click="ExportClipBtn_Click"
                        ToolTip="匯出選取時間範圍的錄影"/>

                <!-- FPS badge -->
                <Border Grid.Column="18" x:Name="FpsBadge"
                        Background="{DynamicResource OverlayBrush}" CornerRadius="3"
                        Padding="4,1" Margin="4,0,0,0"
                        VerticalAlignment="Center" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="FpsText" Text="0 FPS" FontSize="9"
                                   FontWeight="SemiBold" FontFamily="Consolas"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="PerfToggleBtn" Style="{StaticResource SecondaryButton}"
                                Height="14" Width="16" Margin="2,0,0,0" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                Click="PerfToggleBtn_Click" ToolTip="效能監控面板 (Ctrl+M)">
                            <Path Data="{StaticResource IconLayout}" Fill="{DynamicResource SecondaryTextBrush}" Width="8" Height="8" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════ Row 0-3 overlays ═══════ -->

        <!-- Search backdrop (click to dismiss) -->
        <Border x:Name="SearchBackdrop" Grid.RowSpan="4" Background="Transparent"
                Visibility="Collapsed" MouseLeftButtonDown="SearchBackdrop_MouseLeftButtonDown"/>

        <!-- Fullscreen overlay -->
        <Grid x:Name="FullScreenOverlay" Grid.RowSpan="4" Visibility="Collapsed"
              Background="{DynamicResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Height="40" Background="{DynamicResource OverlayBrush}" Padding="12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="FsTimeText" Text="--:--:--"
                               FontSize="16" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="FsBookmarkBtn" Style="{StaticResource SecondaryButton}"
                                Height="26" Width="30" Padding="0" Margin="0,0,4,0"
                                Background="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                                Click="FsBookmarkBtn_Click" ToolTip="標記書籤 (B)">
                            <Path Data="{StaticResource IconBookmark}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                        <Button x:Name="FsSnapshotBtn" Style="{StaticResource SecondaryButton}"
                                Height="26" Width="30" Padding="0" Margin="0,0,4,0"
                                Background="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                                Click="FsSnapshotBtn_Click" ToolTip="拍照">
                            <Path Data="{StaticResource IconSnapshot}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                        <Button x:Name="FsExitBtn" Style="{StaticResource SecondaryButton}"
                                Height="26" Width="30" Padding="0"
                                Background="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                                Click="FsExitBtn_Click" ToolTip="離開全螢幕 (F11)">
                            <Path Data="{StaticResource IconFullScreen}" Fill="{DynamicResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="2" Height="44" Background="{DynamicResource OverlayBrush}" Padding="12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="FsJumpStartBtn" Style="{StaticResource SecondaryButton}"
                            Height="28" Width="30" Background="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                            Click="FsTransportBtn_Click" Tag="jumpStart" ToolTip="跳到開頭">
                        <Path Data="{StaticResource IconSkipBack}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button Grid.Column="1" x:Name="FsStepBackBtn" Style="{StaticResource SecondaryButton}"
                            Height="28" Width="30" Background="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                            Margin="4,0,0,0" Click="FsTransportBtn_Click" Tag="stepBack" ToolTip="上一步">
                        <Path Data="{StaticResource IconRewind}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button Grid.Column="2" x:Name="FsPlayBtn" Style="{StaticResource SecondaryButton}"
                            Height="30" Width="34" FontSize="12"
                            Background="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                            Foreground="{DynamicResource TextBrush}" Margin="4,0,0,0"
                            Click="FsTransportBtn_Click" Tag="play" ToolTip="播放">
                        <Path Data="{StaticResource IconPlay}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button Grid.Column="3" x:Name="FsPauseBtn" Style="{StaticResource SecondaryButton}"
                            Height="28" Width="30" Background="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                            Margin="2,0,0,0" Click="FsTransportBtn_Click" Tag="pause" ToolTip="暫停">
                        <Path Data="{StaticResource IconPause}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button Grid.Column="4" x:Name="FsStepFwdBtn" Style="{StaticResource SecondaryButton}"
                            Height="28" Width="30" Background="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                            Margin="4,0,0,0" Click="FsTransportBtn_Click" Tag="stepFwd" ToolTip="下一步">
                        <Path Data="{StaticResource IconFastForward}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button Grid.Column="5" x:Name="FsJumpEndBtn" Style="{StaticResource SecondaryButton}"
                            Height="28" Width="30" Background="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                            Margin="4,0,0,0" Click="FsTransportBtn_Click" Tag="jumpEnd" ToolTip="跳到結尾">
                        <Path Data="{StaticResource IconSkipForward}" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button Grid.Column="6" x:Name="FsSpeedBtn" Content="1x"
                            Style="{StaticResource SecondaryButton}"
                            Height="28" Width="36" FontSize="10" FontWeight="SemiBold"
                            Background="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                            Margin="4,0,0,0" Click="FsTransportBtn_Click" Tag="speed" ToolTip="播放速度"/>
                    <TextBlock Grid.Column="8" x:Name="FsClockText" Text=""
                               FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Consolas" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Shortcuts overlay -->
        <Border x:Name="ShortcutsOverlay" Grid.RowSpan="4" Visibility="Collapsed"
                Background="{DynamicResource OverlayBrush}"
                MouseDown="ShortcutsOverlay_MouseDown">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Border Background="{DynamicResource BackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10"
                        MaxWidth="560" Margin="0,40,0,40" Padding="24,20" HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="快捷鍵一覽" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                        <TextBlock Text="播放控制" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,6"/>
                        <local:ShortcutRow Key_="Ctrl + P" Desc="全部播放"/>
                        <local:ShortcutRow Key_="Space" Desc="播放 / 暫停"/>
                        <local:ShortcutRow Key_="← / ," Desc="上一幀"/>
                        <local:ShortcutRow Key_="→ / ." Desc="下一幀"/>
                        <local:ShortcutRow Key_="Shift + ," Desc="跳回 10 幀"/>
                        <local:ShortcutRow Key_="Shift + ." Desc="跳前 10 幀"/>
                        <local:ShortcutRow Key_="Ctrl + ←" Desc="跳到開頭"/>
                        <local:ShortcutRow Key_="Ctrl + →" Desc="跳到結尾"/>
